<Window x:Class="WeberIT.Checkup.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weber IT Checkup Assistent"
        Height="720"
        Width="1180"
        MinHeight="650"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Kopfbereich -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="24,0">
            <DockPanel LastChildFill="True">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Weber IT Checkup Assistent"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Professioneller Windows-PC-Check für Privatkunden"
                               Foreground="#CBD5E1"
                               FontSize="13"/>
                </StackPanel>

                <Button Content="Neuer Checkup"
                        Style="{StaticResource AccentButtonStyle}"
                        DockPanel.Dock="Right"
                        Width="150"
                        Height="38"
                        Margin="0,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Hauptbereich -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation -->
            <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="Navigation"
                               Foreground="#9CA3AF"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="24,0,0,12"/>

                    <Button Content="Dashboard"
        Style="{StaticResource NavButtonStyle}"
        Command="{Binding ShowDashboardCommand}" />
                    <Button Content="Kunden"
        Style="{StaticResource NavButtonStyle}"
        Command="{Binding ShowCustomersCommand}" />
                    <Button Content="Geräte" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Checkup starten" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Dokumentation" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Einstellungen" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- Arbeitsbereich -->
            <ContentControl Grid.Column="1"
                Content="{Binding CurrentViewModel}" />
        </Grid>

        <!-- Statusleiste -->
        <Border Grid.Row="2" Background="#E5E7EB" Padding="16,0">
            <DockPanel>
                <TextBlock Text="Bereit"
                           VerticalAlignment="Center"
                           Foreground="#374151"/>
                <TextBlock Text="v0.1.0"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#374151"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>