<Window x:Class="WeberIT.Checkup.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weber IT Checkup Assistent"
        Height="720"
        Width="1180"
        MinHeight="650"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Kopfbereich -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="24,0">
            <DockPanel LastChildFill="True">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Weber IT Checkup Assistent"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Professioneller Windows-PC-Check für Privatkunden"
                               Foreground="#CBD5E1"
                               FontSize="13"/>
                </StackPanel>

                <Button Content="Neuer Checkup"
                        Style="{StaticResource AccentButtonStyle}"
                        DockPanel.Dock="Right"
                        Width="150"
                        Height="38"
                        Margin="0,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Hauptbereich -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation -->
            <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="Navigation"
                               Foreground="#9CA3AF"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="24,0,0,12"/>

                    <Button Content="Dashboard" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Kunden" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Geräte" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Checkup starten" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Dokumentation" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Einstellungen" Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- Arbeitsbereich -->
            <ScrollViewer Grid.Column="1" Padding="28">
                <StackPanel>

                    <TextBlock Text="Dashboard"
                               Style="{StaticResource PageTitleTextStyle}"/>

                    <TextBlock Text="Übersicht über aktuelle Checkups, Kunden und offene Empfehlungen."
                               Style="{StaticResource PageSubtitleTextStyle}"
                               Margin="0,6,0,24"/>

                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,28">
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Letzte Checkups" Foreground="#6B7280"/>
                                <TextBlock Text="0" FontSize="36" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Offene Hinweise" Foreground="#6B7280"/>
                                <TextBlock Text="0" FontSize="36" FontWeight="SemiBold" Foreground="#92400E"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Kritische Befunde" Foreground="#6B7280"/>
                                <TextBlock Text="0" FontSize="36" FontWeight="SemiBold" Foreground="#991B1B"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="12"
                            Padding="24"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Nächster Schritt"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock Text="Starte einen neuen Checkup oder lege zunächst einen Kunden und ein Gerät an."
                                       Foreground="#6B7280"
                                       Margin="0,8,0,18"/>

                            <Button Content="Checkup vorbereiten"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="180"
                                    Height="38"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Statusleiste -->
        <Border Grid.Row="2" Background="#E5E7EB" Padding="16,0">
            <DockPanel>
                <TextBlock Text="Bereit"
                           VerticalAlignment="Center"
                           Foreground="#374151"/>
                <TextBlock Text="v0.1.0"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#374151"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>