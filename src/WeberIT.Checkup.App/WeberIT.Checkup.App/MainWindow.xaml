<Window x:Class="WeberIT.Checkup.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weber IT Checkup Assistent"
        Height="720"
        Width="1180"
        MinHeight="650"
        MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="24,0"
            Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center">

                    <TextBlock
                        Text="Weber IT Checkup Assistent"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock
                        Margin="0,4,0,0"
                        Text="Professioneller Windows-PC-Check für Privatkunden"
                        FontSize="13"
                        Foreground="{StaticResource TextSecondaryBrush}" />

                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="150"
                    Height="38"
                    VerticalAlignment="Center"
                    Content="Neuer Checkup"
                    Command="{Binding ShowCheckupCommand}"
                    Style="{StaticResource AccentButtonStyle}" />

            </Grid>

        </Border>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{StaticResource SecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">

                <StackPanel Margin="0,24,0,0">

                    <TextBlock
                        Margin="26,0,0,12"
                        Text="NAVIGATION"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextMutedBrush}" />

                    <Button
                        Content="Dashboard"
                        Command="{Binding ShowDashboardCommand}"
                        Style="{StaticResource NavButtonStyle}" />

                    <Button
                        Content="Kunden"
                        Command="{Binding ShowCustomersCommand}"
                        Style="{StaticResource NavButtonStyle}" />

                    <Button
                        Content="Gerät / Checkup"
                        Command="{Binding ShowCheckupCommand}"
                        Style="{StaticResource NavButtonStyle}" />

                    <Button
                        Content="Dokumentation"
                        Style="{StaticResource NavButtonStyle}" />

                    <Button
                        Content="Einstellungen"
                        Style="{StaticResource NavButtonStyle}" />

                </StackPanel>

            </Border>

            <ContentControl
                Grid.Column="1"
                Content="{Binding CurrentViewModel}" />

        </Grid>

        <Border
            Grid.Row="2"
            Padding="16,0"
            Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <DockPanel>

                <TextBlock
                    Text="Bereit"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}" />

                <TextBlock
                    Text="v0.1.0"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}" />

            </DockPanel>

        </Border>

    </Grid>

</Window>