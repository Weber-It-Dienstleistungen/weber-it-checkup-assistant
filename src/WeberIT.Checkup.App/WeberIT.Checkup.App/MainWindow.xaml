<Window x:Class="WeberIT.Checkup.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weber IT Checkup Assistent"
        Width="1280"
        Height="800"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <!-- Kopfbereich -->

        <Border
            Grid.Row="0"
            Padding="24,0"
            Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Anwendungssignet -->

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <Border
                        Width="40"
                        Height="40"
                        Margin="0,0,12,0"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="9">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="19"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="&#xE950;" />

                    </Border>

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Weber IT" />

                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="CHECKUP ASSISTENT" />

                    </StackPanel>

                </StackPanel>

                <Border
                    Grid.Column="1"
                    Width="1"
                    Height="38"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource BorderBrush}" />

                <!-- Fenstertitel -->

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center">

                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Professioneller Windows-PC-Check" />

                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Kunden, Geräte und Systembewertungen zentral verwalten" />

                </StackPanel>

                <!-- Hauptaktion -->

                <Button
                    Grid.Column="3"
                    Width="170"
                    Height="40"
                    VerticalAlignment="Center"
                    Command="{Binding ShowCheckupCommand}"
                    Style="{StaticResource AccentButtonStyle}">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock
                            Margin="0,0,9,0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            Text="&#xE710;" />

                        <TextBlock
                            VerticalAlignment="Center"
                            Text="Neuer Checkup" />

                    </StackPanel>

                </Button>

            </Grid>

        </Border>

        <!-- Hauptbereich -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation -->

            <Border
                Grid.Column="0"
                Background="{StaticResource SecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Margin="0,24,0,0">

                        <TextBlock
                            Margin="26,0,0,12"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="NAVIGATION" />

                        <!-- Dashboard -->

                        <Button
                            Command="{Binding ShowDashboardCommand}"
                            Style="{StaticResource NavButtonStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="&#xE80F;" />

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="Dashboard" />

                            </Grid>

                        </Button>

                        <!-- Kunden -->

                        <Button
                            Command="{Binding ShowCustomersCommand}"
                            Style="{StaticResource NavButtonStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="&#xE716;" />

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="Kunden" />

                            </Grid>

                        </Button>

                        <!-- Gerät und Checkup -->

                        <Button
                            Command="{Binding ShowCheckupCommand}"
                            Style="{StaticResource NavButtonStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="&#xE9D9;" />

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="Gerät / Checkup" />

                            </Grid>

                        </Button>

                        <!-- Werkzeuge -->

                        <Button
                            Command="{Binding ShowMaintenanceCommand}"
                            Style="{StaticResource NavButtonStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="&#xE90F;" />

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="Werkzeuge" />

                            </Grid>

                        </Button>

                    </StackPanel>

                    <!-- Seitenleisteninformation -->

                    <Border
                        Grid.Row="2"
                        Margin="16,0,16,18"
                        Padding="14"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">

                        <StackPanel>

                            <StackPanel Orientation="Horizontal">

                                <Border
                                    Width="28"
                                    Height="28"
                                    Margin="0,0,10,0"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    CornerRadius="14">

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="12"
                                        Foreground="{StaticResource SuccessBrush}"
                                        Text="&#xE73E;" />

                                </Border>

                                <StackPanel VerticalAlignment="Center">

                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="System bereit" />

                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="10"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="Lokale Datenbank aktiv" />

                                </StackPanel>

                            </StackPanel>

                            <Border
                                Height="1"
                                Margin="0,12"
                                Background="{StaticResource BorderBrush}" />

                            <TextBlock
                                FontSize="10"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="Alle Kundendaten und Systemchecks werden lokal auf diesem Computer gespeichert."
                                TextWrapping="Wrap" />

                        </StackPanel>

                    </Border>

                </Grid>

            </Border>

            <!-- Seiteninhalt -->

            <ContentControl
                Grid.Column="1"
                Content="{Binding CurrentViewModel}" />

        </Grid>

        <!-- Statusleiste -->

        <Border
            Grid.Row="2"
            Padding="16,0"
            Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse
                    Grid.Column="0"
                    Width="7"
                    Height="7"
                    VerticalAlignment="Center"
                    Fill="{StaticResource SuccessBrush}" />

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="Bereit für den nächsten Systemcheck" />

                <StackPanel
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <TextBlock
                        FontSize="11"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="Weber IT-Dienstleistungen" />

                    <TextBlock
                        Margin="10,0"
                        FontSize="11"
                        Foreground="{StaticResource BorderStrongBrush}"
                        Text="·" />

                    <TextBlock
                        FontSize="11"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="v0.1.0" />

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>