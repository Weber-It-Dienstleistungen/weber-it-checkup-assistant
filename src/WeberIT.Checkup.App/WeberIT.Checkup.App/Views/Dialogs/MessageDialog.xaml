<Window x:Class="WeberIT.Checkup.App.Views.Dialogs.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Width="500"
        Height="310"
        MinWidth="500"
        MinHeight="310"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Margin="28,28,28,24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="48"
                    Height="48"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="24">

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="21"
                        Foreground="{StaticResource WarningBrush}"
                        Text="&#xEA39;" />

                </Border>

                <StackPanel Grid.Column="1">

                    <TextBlock
                        FontSize="21"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{Binding DialogTitle}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="13"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Der Vorgang konnte nicht abgeschlossen werden."
                        TextWrapping="Wrap" />

                </StackPanel>

            </Grid>

            <Border
                Grid.Row="2"
                Padding="16"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="9">

                <TextBlock
                    FontSize="14"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{Binding DialogMessage}"
                    TextWrapping="Wrap" />

            </Border>

        </Grid>

        <Border
            Grid.Row="1"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="Es wurden keine neuen Scandaten übernommen." />

                <Button
                    Grid.Column="1"
                    Width="120"
                    Height="40"
                    Content="Schließen"
                    IsDefault="True"
                    Click="CloseButton_Click"
                    Style="{StaticResource AccentButtonStyle}" />

            </Grid>

        </Border>

    </Grid>

</Window>