<Window
    x:Class="WeberIT.Checkup.App.Views.Dialogs.ProgramUpdateExecutionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Programmupdates ausführen"
    Width="860"
    Height="680"
    MinWidth="720"
    MinHeight="560"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource BackgroundBrush}"
    ContentRendered="Window_OnContentRendered"
    Closing="Window_OnClosing">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Padding="28"
            VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock
                    FontSize="21"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Kontrollierte Programmaktualisierung"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource AccentBrush}"
                    Text="{Binding ActionTitle}"
                    TextWrapping="Wrap" />

                <Border
                    Margin="0,22,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="STATUS" />

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding ExecutionStatusText}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding ExecutionDetailText}"
                            TextWrapping="Wrap" />

                        <ProgressBar
                            Margin="0,14,0,0"
                            Height="6"
                            IsIndeterminate="{Binding IsRunning}">

                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsRunning}"
                                            Value="True">

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>

                        </ProgressBar>

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="WÄHREND DER AUSFÜHRUNG" />

                        <TextBlock
                            Margin="0,7,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Die ausgewählten Pakete werden einzeln und in der zuvor bestätigten Reihenfolge verarbeitet. Nach einem technischen Fehler werden keine weiteren Pakete gestartet."
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="Das Fenster kann während eines laufenden WinGet-Prozesses nicht geschlossen werden. Ein erzwungenes Beenden der Anwendung kann einen begonnenen Paketvorgang in einem undefinierten Zustand hinterlassen."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <TextBlock
                    Margin="0,22,0,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Technische Einzelergebnisse" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding ResultCountText}"
                    TextWrapping="Wrap" />

                <ItemsControl
                    Margin="0,10,0,0"
                    ItemsSource="{Binding CommandResults}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,10"
                                Padding="14"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel>

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{Binding CommandText}"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="16,0,0,0"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding StatusText}" />

                                    </Grid>

                                    <TextBlock
                                        Margin="0,7,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding DetailText}"
                                        TextWrapping="Wrap" />

                                    <TextBox
                                        Margin="0,8,0,0"
                                        MaxHeight="150"
                                        IsReadOnly="True"
                                        Text="{Binding OutputText}"
                                        TextWrapping="Wrap"
                                        VerticalScrollBarVisibility="Auto">

                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter
                                                    Property="Visibility"
                                                    Value="Visible" />

                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding HasOutput}"
                                                        Value="False">

                                                        <Setter
                                                            Property="Visibility"
                                                            Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>

                                    </TextBox>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

                <Border
                    Margin="0,6,0,0"
                    Padding="14"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource InformationBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <TextBlock
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Ein technisch erfolgreicher Updatebefehl schließt die zugehörige Checkup-Aufgabe noch nicht automatisch ab. Der Erfolg muss anschließend durch einen neuen Scan kontrolliert werden."
                        TextWrapping="Wrap" />

                </Border>

            </StackPanel>

        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="{Binding FooterStatusText}"
                    TextWrapping="Wrap" />

                <Button
                    Grid.Column="1"
                    Width="120"
                    Content="Schließen"
                    IsCancel="True"
                    IsEnabled="{Binding CanClose}"
                    Click="CloseButton_OnClick" />

            </Grid>

        </Border>

    </Grid>

</Window>