<Window
    x:Class="WeberIT.Checkup.App.Views.Dialogs.TaskActionPlanPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aktionsplan prüfen"
    Width="860"
    Height="720"
    MinWidth="720"
    MinHeight="600"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Padding="28"
            VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock
                    FontSize="21"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{Binding ActionTitle}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource AccentBrush}"
                    Text="Aktionsplan vollständig prüfen"
                    TextWrapping="Wrap" />

                <Border
                    Margin="0,22,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="AUSGEWÄHLTE ZIELE" />

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding TargetDescription}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="ERWARTETE WIRKUNG" />

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding ExpectedEffect}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="RISIKO" />

                        <TextBlock
                            Margin="0,8,0,0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding RiskLevelText}" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding RiskDescription}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Grid Margin="0,14,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="14"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding AdministratorRequirementText}"
                            TextWrapping="Wrap" />

                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="14"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding RestartPossibilityText}"
                            TextWrapping="Wrap" />

                    </Border>

                </Grid>

                <TextBlock
                    Margin="0,20,0,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Vorgesehene Einzelbefehle" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding CommandCountText}" />

                <ItemsControl
                    Margin="0,10,0,0"
                    ItemsSource="{Binding Commands}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,10"
                                Padding="14"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel>

                                    <TextBox
                                        IsReadOnly="True"
                                        Text="{Binding DisplayText}"
                                        TextWrapping="Wrap"
                                        VerticalScrollBarVisibility="Auto" />

                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="10"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="{Binding AdministratorRequirementText}" />

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

                <Border
                    Margin="0,6,0,0"
                    Padding="14"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="Ausdrückliche Bestätigung erforderlich"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Prüfe Ziele, Risiken und jeden vorgesehenen Einzelbefehl. Die Zustimmung gilt ausschließlich für den oben dargestellten Aktionsplan."
                            TextWrapping="Wrap" />

                        <CheckBox
                            x:Name="ExecutionConfirmationCheckBox"
                            Margin="0,12,0,0"
                            VerticalContentAlignment="Top">

                            <TextBlock
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Ich habe den Aktionsplan vollständig geprüft und bestätige die kontrollierte Ausführung der ausgewählten Programmupdates."
                                TextWrapping="Wrap" />

                        </CheckBox>

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="In dieser Ausbaustufe wird die Zustimmung nur an den aufrufenden Dialog zurückgegeben. Es wird noch kein Befehl gestartet."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="Bestätigungsschritt – noch keine Ausführung"
                    TextWrapping="Wrap" />

                <Button
                    Grid.Column="1"
                    Width="120"
                    Content="Abbrechen"
                    IsCancel="True"
                    Click="CloseButton_OnClick" />

                <Button
                    Grid.Column="3"
                    MinWidth="210"
                    Content="Ausführung bestätigen"
                    IsDefault="True"
                    IsEnabled="{Binding IsChecked, ElementName=ExecutionConfirmationCheckBox}"
                    Click="ConfirmExecutionButton_OnClick" />

            </Grid>

        </Border>

    </Grid>

</Window>