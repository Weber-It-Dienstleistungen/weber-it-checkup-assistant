<Window
    x:Class="WeberIT.Checkup.App.Views.Dialogs.CleanupActionSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:WeberIT.Checkup.App.Models"
    Title="Bereinigungskategorien auswählen"
    Width="880"
    Height="700"
    MinWidth="740"
    MinHeight="580"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource BackgroundBrush}">

    <Window.Resources>

        <Style
            x:Key="CategorySelectionCheckBoxStyle"
            TargetType="{x:Type CheckBox}">

            <Setter
                Property="Width"
                Value="22" />

            <Setter
                Property="Height"
                Value="22" />

            <Setter
                Property="Focusable"
                Value="False" />

            <Setter
                Property="Cursor"
                Value="Hand" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate
                        TargetType="{x:Type CheckBox}">

                        <Border
                            x:Name="SelectionBox"
                            Width="22"
                            Height="22"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource TextMutedBrush}"
                            BorderThickness="2"
                            CornerRadius="4">

                            <Path
                                x:Name="SelectionMark"
                                Width="12"
                                Height="9"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M 1,4 L 5,8 L 11,1"
                                SnapsToDevicePixels="True"
                                Stroke="White"
                                StrokeEndLineCap="Round"
                                StrokeLineJoin="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="2.2"
                                Visibility="Collapsed" />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger
                                Property="IsMouseOver"
                                Value="True">

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />

                            </Trigger>

                            <Trigger
                                Property="IsChecked"
                                Value="True">

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="Background"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    TargetName="SelectionMark"
                                    Property="Visibility"
                                    Value="Visible" />

                            </Trigger>

                            <Trigger
                                Property="IsEnabled"
                                Value="False">

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="Opacity"
                                    Value="0.45" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="28,24"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">

            <StackPanel>

                <TextBlock
                    FontSize="21"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Sichere Bereinigungskategorien auswählen" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Angezeigt werden sicher freigegebene Kategorien mit einem belastbaren Messergebnis. Benutzertemporärdateien dürfen auch bei einer Teilmessung ausgewählt werden; die angezeigten Werte sind dann Mindestwerte."
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,6,0,0"
                    FontSize="11"
                    Foreground="{StaticResource WarningBrush}"
                    Text="Die Auswahl selbst löscht noch nichts. Der Benutzer-Temp-Plan kann erst nach vollständiger Vorschau, Checkbox und ausdrücklicher Bestätigung ausgeführt werden. Andere Kategorien bleiben reine Planvorschauen."
                    TextWrapping="Wrap" />

            </StackPanel>

        </Border>

        <Grid
            Grid.Row="1"
            Margin="28,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{Binding SelectableCategoryCountText}" />

                <Button
                    Grid.Column="1"
                    MinWidth="120"
                    Content="Alle auswählen"
                    IsEnabled="{Binding HasSelectableCategories}"
                    Click="SelectAllButton_OnClick" />

                <Button
                    Grid.Column="3"
                    MinWidth="130"
                    Content="Auswahl aufheben"
                    IsEnabled="{Binding HasSelectableCategories}"
                    Click="ClearSelectionButton_OnClick" />

            </Grid>

            <ListBox
                x:Name="CategoriesListBox"
                Grid.Row="2"
                ItemsSource="{Binding AvailableCategories}"
                SelectionMode="Multiple"
                Background="Transparent"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectionChanged="CategoriesListBox_OnSelectionChanged">

                <ListBox.ItemContainerStyle>

                    <Style
                        TargetType="ListBoxItem"
                        BasedOn="{StaticResource {x:Type ListBoxItem}}">

                        <Setter
                            Property="HorizontalContentAlignment"
                            Value="Stretch" />

                        <Setter
                            Property="Padding"
                            Value="0" />

                    </Style>

                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Margin="5"
                            Padding="14"
                            CornerRadius="7">

                            <Border.Style>

                                <Style TargetType="Border">

                                    <Setter
                                        Property="Background"
                                        Value="{StaticResource SurfaceSecondaryBrush}" />

                                    <Setter
                                        Property="BorderBrush"
                                        Value="{StaticResource BorderBrush}" />

                                    <Setter
                                        Property="BorderThickness"
                                        Value="1" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                            Value="True">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource AccentBrush}" />

                                            <Setter
                                                Property="BorderThickness"
                                                Value="2" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </Border.Style>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="210" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    Grid.Column="0"
                                    Margin="0,2,12,0"
                                    VerticalAlignment="Top"
                                    IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Mode=TwoWay}"
                                    Style="{StaticResource CategorySelectionCheckBoxStyle}" />

                                <StackPanel Grid.Column="1">

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding Title}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,6,18,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding TargetAreaDescription}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                                <StackPanel Grid.Column="2">

                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Text="{Binding MeasurementStatusText}">

                                        <TextBlock.Style>

                                            <Style TargetType="{x:Type TextBlock}">

                                                <Setter
                                                    Property="Foreground"
                                                    Value="{StaticResource SuccessBrush}" />

                                                <Style.Triggers>

                                                    <DataTrigger
                                                        Binding="{Binding MeasurementStatus}"
                                                        Value="{x:Static models:CleanupMeasurementStatus.PartiallyMeasured}">

                                                        <Setter
                                                            Property="Foreground"
                                                            Value="{StaticResource WarningBrush}" />

                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>

                                        </TextBlock.Style>

                                    </TextBlock>

                                    <TextBlock
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding MeasurementSummaryText}"
                                        TextAlignment="Right"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ListBox.ItemTemplate>

            </ListBox>

            <Border
                Grid.Row="4"
                Padding="12"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource InformationBrush}"
                BorderThickness="1"
                CornerRadius="7">

                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding SelectionStatusText}"
                    TextWrapping="Wrap" />

            </Border>

        </Grid>

        <Border
            Grid.Row="2"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="Ausführung ausschließlich nach separater Bestätigung"
                    TextWrapping="Wrap" />

                <Button
                    Grid.Column="1"
                    Width="120"
                    Content="Schließen"
                    IsCancel="True"
                    Click="CloseButton_OnClick" />

                <Button
                    x:Name="PreviewPlanButton"
                    Grid.Column="3"
                    MinWidth="170"
                    Content="Aktionsplan prüfen"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="PreviewPlanButton_OnClick" />

            </Grid>

        </Border>

    </Grid>

</Window>