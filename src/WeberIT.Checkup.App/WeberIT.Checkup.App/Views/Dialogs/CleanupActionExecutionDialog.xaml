<Window
    x:Class="WeberIT.Checkup.App.Views.Dialogs.CleanupActionExecutionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Bereinigung ausführen"
    Width="860"
    Height="720"
    MinWidth="720"
    MinHeight="580"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource BackgroundBrush}"
    ContentRendered="Window_OnContentRendered"
    Closing="Window_OnClosing">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Padding="28"
            VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock
                    FontSize="21"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Kontrollierte Bereinigung"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource AccentBrush}"
                    Text="{Binding ActionTitle}"
                    TextWrapping="Wrap" />

                <Border
                    Margin="0,22,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="STATUS" />

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding ExecutionStatusText}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding ExecutionDetailText}"
                            TextWrapping="Wrap" />

                        <ProgressBar
                            Margin="0,14,0,0"
                            Height="6"
                            IsIndeterminate="{Binding IsRunning}">

                            <ProgressBar.Style>

                                <Style TargetType="ProgressBar">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding IsRunning}"
                                            Value="True">

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </ProgressBar.Style>

                        </ProgressBar>

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="WÄHREND DER AUSFÜHRUNG" />

                        <TextBlock
                            Margin="0,7,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Der bestätigte Plan wird erneut geprüft. Anschließend werden ausschließlich Inhalte des freigegebenen Benutzer-Temp-Ordners verarbeitet."
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="Ein Abbruch stoppt die Verarbeitung vor dem nächsten Eintrag. Bereits gelöschte Dateien können nicht wiederhergestellt werden. Das Fenster bleibt bis zum kontrollierten Ende geöffnet."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <TextBlock
                    Margin="0,22,0,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Technische Einzelergebnisse" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding ResultCountText}"
                    TextWrapping="Wrap" />

                <ItemsControl
                    Margin="0,10,0,0"
                    ItemsSource="{Binding CategoryResults}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,10"
                                Padding="14"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel>

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{Binding CategoryTitle}"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="16,0,0,0"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding StatusText}"
                                            TextAlignment="Right"
                                            TextWrapping="Wrap" />

                                    </Grid>

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="AUSGEFÜHRTER ZIELPFAD" />

                                    <TextBox
                                        Margin="0,5,0,0"
                                        IsReadOnly="True"
                                        Text="{Binding TargetPathText, Mode=OneWay}"
                                        TextWrapping="Wrap" />

                                    <Grid Margin="0,10,0,0">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">

                                            <TextBlock
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{Binding DeletedFileCountText}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding DeletedDirectoryCountText}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding DeletedSizeText}"
                                                TextWrapping="Wrap" />

                                        </StackPanel>

                                        <StackPanel Grid.Column="2">

                                            <TextBlock
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{Binding FailureCountText}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding SkippedEntryCountText}"
                                                TextWrapping="Wrap" />

                                        </StackPanel>

                                    </Grid>

                                    <Border
                                        Margin="0,10,0,0"
                                        Padding="10"
                                        Background="{StaticResource SurfaceSecondaryBrush}"
                                        BorderBrush="{StaticResource WarningBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">

                                        <Border.Style>

                                            <Style TargetType="Border">

                                                <Setter
                                                    Property="Visibility"
                                                    Value="Collapsed" />

                                                <Style.Triggers>

                                                    <DataTrigger
                                                        Binding="{Binding HasError}"
                                                        Value="True">

                                                        <Setter
                                                            Property="Visibility"
                                                            Value="Visible" />

                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>

                                        </Border.Style>

                                        <TextBlock
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding ErrorText}"
                                            TextWrapping="Wrap" />

                                    </Border>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

                <Border
                    Margin="0,6,0,0"
                    Padding="14"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource InformationBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <TextBlock
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Auch eine technisch erfolgreiche Bereinigung schließt die Checkup-Aufgabe nicht automatisch ab. Das tatsächliche Ergebnis muss anschließend durch einen neuen Scan kontrolliert werden."
                        TextWrapping="Wrap" />

                </Border>

            </StackPanel>

        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="{Binding FooterStatusText}"
                    TextWrapping="Wrap" />

                <Button
                    Grid.Column="1"
                    MinWidth="170"
                    Content="Ausführung abbrechen"
                    IsEnabled="{Binding CanCancel}"
                    Click="CancelButton_OnClick" />

                <Button
                    Grid.Column="3"
                    Width="120"
                    Content="Schließen"
                    IsCancel="True"
                    IsEnabled="{Binding CanClose}"
                    Click="CloseButton_OnClick" />

            </Grid>

        </Border>

    </Grid>

</Window>