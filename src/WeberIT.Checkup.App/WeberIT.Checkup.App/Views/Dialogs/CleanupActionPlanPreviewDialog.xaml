<Window
    x:Class="WeberIT.Checkup.App.Views.Dialogs.CleanupActionPlanPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Bereinigungsplan prüfen"
    Width="880"
    Height="740"
    MinWidth="740"
    MinHeight="600"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Padding="28"
            VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock
                    FontSize="21"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{Binding ActionTitle}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource AccentBrush}"
                    Text="Kontrollierten Bereinigungsplan vollständig prüfen"
                    TextWrapping="Wrap" />

                <Border
                    Margin="0,20,0,0"
                    Padding="14"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource InformationBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource InformationBrush}"
                            Text="Reine Planvorschau"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Dieser Dialog besitzt bewusst keine Ausführungsfunktion. Es werden weder Dateien gelöscht noch externe Prozesse gestartet."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="AUSGEWÄHLTE ZIELE" />

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding TargetDescription}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="ERWARTETE WIRKUNG" />

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding ExpectedEffect}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="RISIKO" />

                        <TextBlock
                            Margin="0,8,0,0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding RiskLevelText}" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding RiskDescription}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Grid Margin="0,14,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="14"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding AdministratorRequirementText}"
                            TextWrapping="Wrap" />

                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="14"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding RestartPossibilityText}"
                            TextWrapping="Wrap" />

                    </Border>

                </Grid>

                <TextBlock
                    Margin="0,20,0,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Vorgesehene Bereinigungskategorien" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding CleanupCategoryCountText}" />

                <ItemsControl
                    Margin="0,10,0,0"
                    ItemsSource="{Binding CleanupCategories}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,10"
                                Padding="14"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel>

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{Binding Title}"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="18,0,0,0"
                                            FontSize="11"
                                            Foreground="{StaticResource SuccessBrush}"
                                            Text="{Binding MeasurementSummaryText}"
                                            TextAlignment="Right"
                                            TextWrapping="Wrap" />

                                    </Grid>

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="KONKRETER ZIELBEREICH" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding TargetAreaDescription}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="Keine Löschung und keine Prozessausführung möglich"
                    TextWrapping="Wrap" />

                <Button
                    Grid.Column="1"
                    MinWidth="190"
                    Content="Planvorschau schließen"
                    IsCancel="True"
                    IsDefault="True"
                    Click="CloseButton_OnClick" />

            </Grid>

        </Border>

    </Grid>

</Window>