<Window
    x:Class="WeberIT.Checkup.App.Views.Dialogs.CleanupActionPlanPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Bereinigungsplan prüfen"
    Width="880"
    Height="790"
    MinWidth="740"
    MinHeight="620"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Background="{StaticResource BackgroundBrush}">

    <Window.Resources>

        <Style
            x:Key="ExecutionConfirmationCheckBoxStyle"
            TargetType="{x:Type CheckBox}">

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="Cursor"
                Value="Hand" />

            <Setter
                Property="Focusable"
                Value="True" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate
                        TargetType="{x:Type CheckBox}">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="SelectionBox"
                                Grid.Column="0"
                                Width="24"
                                Height="24"
                                VerticalAlignment="Top"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource TextMutedBrush}"
                                BorderThickness="2"
                                CornerRadius="4">

                                <Path
                                    x:Name="SelectionMark"
                                    Width="13"
                                    Height="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Data="M 1,5 L 5,9 L 12,1"
                                    SnapsToDevicePixels="True"
                                    Stroke="White"
                                    StrokeEndLineCap="Round"
                                    StrokeLineJoin="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.3"
                                    Visibility="Collapsed" />

                            </Border>

                            <ContentPresenter
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                RecognizesAccessKey="True"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger
                                Property="IsMouseOver"
                                Value="True">

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />

                            </Trigger>

                            <Trigger
                                Property="IsKeyboardFocused"
                                Value="True">

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />

                            </Trigger>

                            <Trigger
                                Property="IsChecked"
                                Value="True">

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="Background"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    TargetName="SelectionBox"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}" />

                                <Setter
                                    TargetName="SelectionMark"
                                    Property="Visibility"
                                    Value="Visible" />

                            </Trigger>

                            <Trigger
                                Property="IsEnabled"
                                Value="False">

                                <Setter
                                    Property="Opacity"
                                    Value="0.45" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Padding="28"
            VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock
                    FontSize="21"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{Binding ActionTitle}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource AccentBrush}"
                    Text="Kontrollierten Bereinigungsplan vollständig prüfen"
                    TextWrapping="Wrap" />

                <Border
                    x:Name="ExecutionAvailableNotice"
                    Margin="0,20,0,0"
                    Padding="14"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource SuccessBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">

                    <StackPanel>

                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="Kontrollierte Ausführung verfügbar"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Dieser Plan enthält genau eine sicher freigegebene Bereinigungskategorie. Nach vollständiger Prüfung und ausdrücklicher Bestätigung kann diese einzelne Kategorie ausgeführt werden."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    x:Name="PurePreviewNotice"
                    Margin="0,20,0,0"
                    Padding="14"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource InformationBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource InformationBrush}"
                            Text="Reine Planvorschau"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Für diese Auswahl ist noch keine technische Ausführung freigegeben. Es werden weder Dateien gelöscht noch externe Prozesse gestartet."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="AUSGEWÄHLTE ZIELE" />

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding TargetDescription}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="ERWARTETE WIRKUNG" />

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding ExpectedEffect}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Border
                    Margin="0,14,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="RISIKO" />

                        <TextBlock
                            Margin="0,8,0,0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding RiskLevelText}" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding RiskDescription}"
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

                <Grid Margin="0,14,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="14"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding AdministratorRequirementText}"
                            TextWrapping="Wrap" />

                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="14"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding RestartPossibilityText}"
                            TextWrapping="Wrap" />

                    </Border>

                </Grid>

                <TextBlock
                    Margin="0,20,0,0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Vorgesehene Bereinigungskategorien" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding CleanupCategoryCountText}" />

                <ItemsControl
                    Margin="0,10,0,0"
                    ItemsSource="{Binding CleanupCategories}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,10"
                                Padding="14"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">

                                <StackPanel>

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{Binding Title}"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="18,0,0,0"
                                            FontSize="11"
                                            Foreground="{StaticResource SuccessBrush}"
                                            Text="{Binding MeasurementSummaryText}"
                                            TextAlignment="Right"
                                            TextWrapping="Wrap" />

                                    </Grid>

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="KONKRETER ZIELBEREICH" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding TargetAreaDescription}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

                <Border
                    x:Name="ExecutionConfirmationPanel"
                    Margin="0,12,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Visibility="Collapsed">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="AUSFÜHRUNG AUSDRÜCKLICH BESTÄTIGEN" />

                        <CheckBox
                            x:Name="ExecutionConfirmationCheckBox"
                            Margin="0,12,0,0"
                            Style="{StaticResource ExecutionConfirmationCheckBoxStyle}"
                            Checked="ExecutionConfirmationCheckBox_OnChanged"
                            Unchecked="ExecutionConfirmationCheckBox_OnChanged">

                            <TextBlock
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Ich habe den angezeigten Zielbereich vollständig geprüft und bestätige die kontrollierte Bereinigung dieser einzelnen Kategorie."
                                TextWrapping="Wrap" />

                        </CheckBox>

                        <TextBlock
                            Margin="36,10,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Geöffnete oder gesperrte Dateien können übersprungen werden. Nicht freigegebene Dateien und die Zielordner selbst bleiben bestehen. Das Ergebnis wird anschließend im Checkup protokolliert."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="FooterStatusTextBlock"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="Keine Löschung und keine Prozessausführung möglich"
                    TextWrapping="Wrap" />

                <Button
                    x:Name="CloseButton"
                    Grid.Column="1"
                    MinWidth="150"
                    Content="Planvorschau schließen"
                    IsCancel="True"
                    Click="CloseButton_OnClick" />

                <Button
                    x:Name="StartCleanupButton"
                    Grid.Column="3"
                    MinWidth="190"
                    Content="Bereinigung starten"
                    IsDefault="True"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}"
                    Visibility="Collapsed"
                    Click="StartCleanupButton_OnClick" />

            </Grid>

        </Border>

    </Grid>

</Window>