<Window x:Class="WeberIT.Checkup.App.Views.Dialogs.CustomerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kunde"
        Height="560"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="Kunde"
            Style="{StaticResource PageTitleTextStyle}" />

        <StackPanel Grid.Row="2">

            <TextBlock
                Text="Vorname"
                Style="{StaticResource FormLabelTextStyle}" />

            <TextBox
                Style="{StaticResource FormTextBoxStyle}" />

            <TextBlock
                Text="Nachname"
                Style="{StaticResource FormLabelTextStyle}" />

            <TextBox
                Style="{StaticResource FormTextBoxStyle}" />

            <TextBlock
                Text="E-Mail"
                Style="{StaticResource FormLabelTextStyle}" />

            <TextBox
                Style="{StaticResource FormTextBoxStyle}" />

            <TextBlock
                Text="Telefon"
                Style="{StaticResource FormLabelTextStyle}" />

            <TextBox
                Style="{StaticResource FormTextBoxStyle}" />

            <TextBlock
                Text="Straße"
                Style="{StaticResource FormLabelTextStyle}" />

            <TextBox
                Style="{StaticResource FormTextBoxStyle}" />

            <Grid Margin="0,0,0,16">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        Text="PLZ"
                        Style="{StaticResource FormLabelTextStyle}" />

                    <TextBox
                        Style="{StaticResource FormTextBoxStyle}"
                        Margin="0"/>

                </StackPanel>

                <StackPanel Grid.Column="2">

                    <TextBlock
                        Text="Ort"
                        Style="{StaticResource FormLabelTextStyle}" />

                    <TextBox
                        Style="{StaticResource FormTextBoxStyle}"
                        Margin="0"/>

                </StackPanel>

            </Grid>

        </StackPanel>

        <StackPanel
            Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right">

            <Button
                Width="110"
                Margin="0,0,12,0"
                Content="Abbrechen" />

            <Button
                Width="110"
                Content="Speichern" />

        </StackPanel>

    </Grid>

</Window>