<Window x:Class="WeberIT.Checkup.App.Views.Dialogs.CustomerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="680"
        Height="680"
        MinWidth="680"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Dialogkopf -->

        <Border
            Grid.Row="0"
            Padding="28,24"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="54" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="42"
                    Height="42"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    CornerRadius="10">

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="19"
                        Foreground="{StaticResource AccentBrush}"
                        Text="&#xE77B;" />

                </Border>

                <StackPanel Grid.Column="1">

                    <TextBlock
                        Text="{Binding Title}"
                        Style="{StaticResource PageTitleTextStyle}" />

                    <TextBlock
                        Margin="0,4,0,0"
                        Text="Erfassen und verwalten Sie die Stamm- und Kontaktdaten des Kunden."
                        Style="{StaticResource PageSubtitleTextStyle}" />

                </StackPanel>

            </Grid>

        </Border>

        <!-- Formular -->

        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="28,24">

                <!-- Kundennummer -->

                <Border
                    Padding="18"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center">

                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Kundennummer" />

                            <TextBlock
                                Margin="0,4,20,0"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Die Kundennummer wird automatisch vergeben und kann nicht verändert werden."
                                TextWrapping="Wrap" />

                        </StackPanel>

                        <TextBox
                            Grid.Column="1"
                            Height="40"
                            Padding="12,0"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            IsReadOnly="True"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            Text="{Binding CustomerNumber, Mode=OneWay}" />

                    </Grid>

                </Border>

                <!-- Stammdaten -->

                <Border
                    Margin="0,18,0,0"
                    Padding="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">

                    <StackPanel>

                        <TextBlock
                            Text="Stammdaten"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,4,0,18"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Name und persönliche Zuordnung des Kunden." />

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">

                                <TextBlock
                                    Text="Vorname"
                                    Style="{StaticResource FormLabelTextStyle}" />

                                <TextBox
                                    Style="{StaticResource FormTextBoxStyle}"
                                    Margin="0"
                                    Text="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>

                            <StackPanel Grid.Column="2">

                                <TextBlock
                                    Text="Nachname"
                                    Style="{StaticResource FormLabelTextStyle}" />

                                <TextBox
                                    Style="{StaticResource FormTextBoxStyle}"
                                    Margin="0"
                                    Text="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>

                        </Grid>

                    </StackPanel>

                </Border>

                <!-- Kontaktdaten -->

                <Border
                    Margin="0,18,0,0"
                    Padding="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">

                    <StackPanel>

                        <TextBlock
                            Text="Kontaktdaten"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,4,0,18"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Telefonische und elektronische Erreichbarkeit." />

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">

                                <TextBlock
                                    Text="E-Mail"
                                    Style="{StaticResource FormLabelTextStyle}" />

                                <TextBox
                                    Style="{StaticResource FormTextBoxStyle}"
                                    Margin="0"
                                    Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>

                            <StackPanel Grid.Column="2">

                                <TextBlock
                                    Text="Telefon"
                                    Style="{StaticResource FormLabelTextStyle}" />

                                <TextBox
                                    Style="{StaticResource FormTextBoxStyle}"
                                    Margin="0"
                                    Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>

                        </Grid>

                    </StackPanel>

                </Border>

                <!-- Anschrift -->

                <Border
                    Margin="0,18,0,0"
                    Padding="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">

                    <StackPanel>

                        <TextBlock
                            Text="Anschrift"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,4,0,18"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Postanschrift des Kunden." />

                        <TextBlock
                            Text="Straße und Hausnummer"
                            Style="{StaticResource FormLabelTextStyle}" />

                        <TextBox
                            Style="{StaticResource FormTextBoxStyle}"
                            Margin="0,0,0,16"
                            Text="{Binding Street, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">

                                <TextBlock
                                    Text="PLZ"
                                    Style="{StaticResource FormLabelTextStyle}" />

                                <TextBox
                                    Style="{StaticResource FormTextBoxStyle}"
                                    Margin="0"
                                    Text="{Binding PostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>

                            <StackPanel Grid.Column="2">

                                <TextBlock
                                    Text="Ort"
                                    Style="{StaticResource FormLabelTextStyle}" />

                                <TextBox
                                    Style="{StaticResource FormTextBoxStyle}"
                                    Margin="0"
                                    Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            </StackPanel>

                        </Grid>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

        <!-- Aktionen -->

        <Border
            Grid.Row="2"
            Padding="28,18"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="Alle Änderungen werden erst beim Speichern übernommen." />

                <Button
                    Grid.Column="1"
                    Width="120"
                    Height="40"
                    Content="Abbrechen"
                    IsCancel="True" />

                <Button
                    Grid.Column="3"
                    Width="120"
                    Height="40"
                    Content="Speichern"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Style="{StaticResource AccentButtonStyle}" />

            </Grid>

        </Border>

    </Grid>

</Window>