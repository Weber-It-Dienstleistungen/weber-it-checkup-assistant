<UserControl
    x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.StartupInformationCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:WeberIT.Checkup.App.Models">

    <Border Style="{StaticResource PanelCardStyle}">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        Text="Autostartanalyse"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Rein lesende Analyse unterstützter lokaler Autostartquellen."
                        TextWrapping="Wrap" />

                </StackPanel>

                <Border
                    Grid.Column="1"
                    Margin="20,0,0,0"
                    Padding="10,6"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">

                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{Binding AnalysisStatusText}"
                        TextWrapping="Wrap" />

                </Border>

            </Grid>

            <Border
                Margin="0,18,0,0"
                Padding="14"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <StackPanel>

                    <TextBlock
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{Binding AnalysisMessageText}"
                        TextWrapping="Wrap" />

                    <Grid Margin="0,14,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Text="Analysezeitpunkt:" />

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding AnalysisDateText}" />

                        <TextBlock
                            Grid.Column="2"
                            Margin="20,0,0,0"
                            FontWeight="SemiBold"
                            Text="Analysedauer:" />

                        <TextBlock
                            Grid.Column="3"
                            Text="{Binding AnalysisDurationText}" />

                    </Grid>

                </StackPanel>

            </Border>

            <Grid Margin="0,18,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="12"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Insgesamt" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{Binding TotalEntryCount}" />

                    </StackPanel>

                </Border>

                <Border
                    Grid.Column="2"
                    Padding="12"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource SuccessBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Aktiv" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{Binding EnabledEntryCount}" />

                    </StackPanel>

                </Border>

                <Border
                    Grid.Column="4"
                    Padding="12"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource TextMutedBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Deaktiviert" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{Binding DisabledEntryCount}" />

                    </StackPanel>

                </Border>

                <Border
                    Grid.Column="6"
                    Padding="12"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Manuell prüfen"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{Binding ConspicuousEntryCount}" />

                    </StackPanel>

                </Border>

            </Grid>

            <Border
                Margin="0,18,0,0"
                Padding="12"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="1"
                CornerRadius="7">

                <Border.Style>

                    <Style TargetType="Border">

                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>

                            <DataTrigger
                                Binding="{Binding HasFailedOrIncompleteAnalysis}"
                                Value="True">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Border.Style>

                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Die Autostartanalyse war nicht vollständig. Die angezeigte Liste kann deshalb unvollständig sein."
                    TextWrapping="Wrap" />

            </Border>

            <TextBlock
                Margin="0,22,0,0"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Erkannte Autostarteinträge" />

            <ItemsControl
                Margin="0,10,0,0"
                ItemsSource="{Binding Entries}">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Border.Style>

                                <Style TargetType="Border">

                                    <Setter
                                        Property="BorderBrush"
                                        Value="{StaticResource BorderBrush}" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding Classification}"
                                            Value="{x:Static models:StartupClassification.Conspicuous}">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource WarningBrush}" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding State}"
                                            Value="{x:Static models:StartupEntryState.Disabled}">

                                            <Setter
                                                Property="Opacity"
                                                Value="0.72" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </Border.Style>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding DisplayNameText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding ProductNameText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="{Binding PublisherText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding DescriptionText}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="20,0,0,0">

                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="Quelle" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{Binding SourceText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding ContextText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="{Binding RegistryViewText}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    Margin="20,0,0,0">

                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="Status und Ziel" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{Binding StateText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding TargetTypeText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="{Binding TargetStatusText}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                                <Border
                                    Grid.Column="3"
                                    Margin="20,0,0,0"
                                    Padding="8,5"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="{Binding ClassificationText}"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />

                                </Border>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <TextBlock
                Margin="0,10,0,0"
                FontSize="11"
                Foreground="{StaticResource TextMutedBrush}"
                Text="Untersucht wurden Run- und RunOnce-Schlüssel sowie die Autostartordner des aktuellen und aller Benutzer. Geplante Aufgaben und Windows-Dienste sind nicht Bestandteil dieser Analyse. Es wurde kein Eintrag gestartet, deaktiviert, verändert oder gelöscht."
                TextWrapping="Wrap" />

        </StackPanel>

    </Border>

</UserControl>