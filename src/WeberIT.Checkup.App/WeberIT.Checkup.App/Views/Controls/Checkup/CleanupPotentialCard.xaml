<UserControl
    x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.CleanupPotentialCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource PanelCardStyle}">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        Text="Bereinigungspotenzial"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Rein lesende Größenanalyse ausgewählter temporärer Dateien und Cachebereiche."
                        TextWrapping="Wrap" />

                </StackPanel>

                <Border
                    Grid.Column="1"
                    Margin="20,0,0,0"
                    Padding="10,6"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">

                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{Binding AnalysisStatusText}"
                        TextWrapping="Wrap" />

                </Border>

            </Grid>

            <Border
                Margin="0,18,0,0"
                Padding="14"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <StackPanel>

                    <TextBlock
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{Binding AnalysisMessageText}"
                        TextWrapping="Wrap" />

                    <Grid Margin="0,14,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Text="Systemvolume:" />

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="{Binding TargetVolumeText}" />

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="20,0,0,0"
                            FontWeight="SemiBold"
                            Text="Analysedauer:" />

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="3"
                            Text="{Binding AnalysisDurationText}" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,10,0,0"
                            FontWeight="SemiBold"
                            Text="Analysezeitpunkt:" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,10,0,0"
                            Text="{Binding AnalysisDateText}" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="20,10,0,0"
                            FontWeight="SemiBold"
                            Text="Analyseumfang:" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Margin="0,10,0,0"
                            Text="{Binding ScopeDescriptionText}"
                            TextWrapping="Wrap" />

                    </Grid>

                </StackPanel>

            </Border>

            <Grid Margin="0,18,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="14"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource SuccessBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Voraussichtlich unkritisches Potenzial"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding SafePotentialSizeText}" />

                    </StackPanel>

                </Border>

                <Border
                    Grid.Column="2"
                    Padding="14"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Nur nach manueller Prüfung"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding ManualReviewPotentialSizeText}" />

                    </StackPanel>

                </Border>

            </Grid>

            <TextBlock
                Margin="0,22,0,0"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Analysierte Kategorien" />

            <ItemsControl
                Margin="0,10,0,0"
                ItemsSource="{Binding Categories}">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding CategoryText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="20,0,0,0">

                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="{Binding ClassificationText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontWeight="SemiBold"
                                        Text="{Binding SizeText}" />

                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="{Binding FileCountText}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                                <Border
                                    Grid.Column="2"
                                    Margin="20,0,0,0"
                                    Padding="8,5"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="{Binding MeasurementStatusText}"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />

                                </Border>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <TextBlock
                Margin="0,10,0,0"
                FontSize="11"
                Foreground="{StaticResource TextMutedBrush}"
                Text="Die angezeigten Größen sind keine automatische Löschfreigabe. Es wurden keine Dateien geöffnet, verändert, verschoben oder gelöscht."
                TextWrapping="Wrap" />

        </StackPanel>

    </Border>

</UserControl>