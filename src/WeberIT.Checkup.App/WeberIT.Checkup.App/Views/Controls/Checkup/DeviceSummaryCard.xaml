<UserControl
    x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.DeviceSummaryCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource PanelCardStyle}">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Gerätebereich -->

            <Border
                Grid.Column="0"
                Padding="24"
                Background="{StaticResource PrimaryBrush}"
                CornerRadius="10">

                <StackPanel>

                    <Border
                        Width="56"
                        Height="56"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SecondaryBrush}"
                        CornerRadius="12">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI Emoji"
                            FontSize="28"
                            Foreground="{StaticResource SurfaceBrush}"
                            Text="🖥" />

                    </Border>

                    <TextBlock
                        Margin="0,24,0,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource BorderBrush}"
                        Text="GERÄT"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SurfaceBrush}"
                        Text="{Binding DeviceInformation.Name}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="15"
                        Foreground="{StaticResource BorderBrush}"
                        Text="{Binding DeviceInformation.DeviceType}"
                        TextWrapping="Wrap" />

                    <Border
                        Margin="0,24,0,0"
                        Padding="12,8"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SecondaryBrush}"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource SurfaceBrush}"
                            Text="{Binding OperatingSystemInformation.Name}"
                            TextWrapping="Wrap" />

                    </Border>

                </StackPanel>

            </Border>

            <!-- Systemübersicht -->

            <StackPanel Grid.Column="2">

                <TextBlock
                    Text="Systemübersicht"
                    Style="{StaticResource SectionTitleTextStyle}" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Die wichtigsten Geräteinformationen sowie System- und Hardwarezustand auf einen Blick."
                    TextWrapping="Wrap" />

                <Grid Margin="0,24,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Hersteller -->

                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="HERSTELLER" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding DeviceInformation.Manufacturer}"
                                TextWrapping="Wrap" />

                        </StackPanel>

                    </Border>

                    <!-- Modell -->

                    <Border
                        Grid.Row="0"
                        Grid.Column="2"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="MODELL" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding DeviceInformation.Model}"
                                TextWrapping="Wrap" />

                        </StackPanel>

                    </Border>

                    <!-- Betriebssystem -->

                    <Border
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="BETRIEBSSYSTEM" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding OperatingSystemInformation.Name}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}">

                                <TextBlock.Text>

                                    <MultiBinding StringFormat="Version {0} · Build {1}">
                                        <Binding Path="OperatingSystemInformation.Version" />
                                        <Binding Path="OperatingSystemInformation.BuildNumber" />
                                    </MultiBinding>

                                </TextBlock.Text>

                            </TextBlock>

                        </StackPanel>

                    </Border>

                    <!-- Scanzeit -->

                    <Border
                        Grid.Row="2"
                        Grid.Column="2"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="LETZTER SCAN" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}">

                                <TextBlock.Text>

                                    <MultiBinding StringFormat="{}{0:dd.MM.yyyy}">
                                        <Binding Path="ScanDate" />
                                    </MultiBinding>

                                </TextBlock.Text>

                            </TextBlock>

                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}">

                                <TextBlock.Text>

                                    <MultiBinding StringFormat="{}{0:HH:mm} Uhr">
                                        <Binding Path="ScanDate" />
                                    </MultiBinding>

                                </TextBlock.Text>

                            </TextBlock>

                        </StackPanel>

                    </Border>

                </Grid>

                <!-- Seriennummer -->

                <Border
                    Margin="0,16,0,0"
                    Padding="16,12"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Seriennummer" />

                        <TextBlock
                            Grid.Column="1"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding DeviceInformation.SerialNumber}"
                            TextWrapping="Wrap" />

                    </Grid>

                </Border>

                <!-- Systemzustand -->

                <Border
                    Margin="0,16,0,0"
                    Padding="18"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="SYSTEMZUSTAND" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="25"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource AccentBrush}"
                                Text="{Binding Assessment.SystemCondition.ScoreText}" />

                            <TextBlock
                                Margin="0,5,0,0"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding Assessment.SystemCondition.RatingText}"
                                TextWrapping="Wrap" />

                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding Assessment.SystemCondition.DataQualityText}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,5,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="{Binding Assessment.SystemCondition.CoverageText}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,10,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding Assessment.SystemCondition.SummaryText}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,10,0,0"
                                FontSize="11"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="Der Systemzustand bewertet wartungs-, software- und konfigurationsbezogene Bereiche. Er ist keine Aussage über den physischen Hardwarezustand oder den Abschlussgrad des Checkups."
                                TextWrapping="Wrap" />

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- Hardwarezustand -->

                <Border
                    Margin="0,16,0,0"
                    Padding="18"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource InformationBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="HARDWAREZUSTAND" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="25"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource InformationBrush}"
                                Text="{Binding Assessment.HardwareCondition.ScoreText}" />

                            <TextBlock
                                Margin="0,5,0,0"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding Assessment.HardwareCondition.RatingText}"
                                TextWrapping="Wrap" />

                        </StackPanel>

                        <StackPanel Grid.Column="2">

                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding Assessment.HardwareCondition.DataQualityText}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,5,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="{Binding Assessment.HardwareCondition.CoverageText}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,10,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding Assessment.HardwareCondition.SummaryText}"
                                TextWrapping="Wrap" />

                            <Border
                                Margin="0,12,0,0"
                                Padding="12,9"
                                Background="{StaticResource BackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">

                                <StackPanel>

                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="PLANUNGSHINWEIS" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding Assessment.HardwarePlanningHorizonText}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding Assessment.HardwarePlanningSummaryText}"
                                        TextWrapping="Wrap" />

                                </StackPanel>

                            </Border>

                            <TextBlock
                                Margin="0,10,0,0"
                                FontSize="11"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="Der Hardwarezustand bewertet nur belastbare Ausstattungs- und Gesundheitsinformationen. Er behauptet keine Restlebensdauer. Treiber-, Update- und Konfigurationsprobleme wirken ausschließlich auf den Systemzustand."
                                TextWrapping="Wrap" />

                        </StackPanel>

                    </Grid>

                </Border>

                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right"
                    FontSize="10"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="{Binding Assessment.ScoringVersionText}" />

            </StackPanel>

        </Grid>

    </Border>

</UserControl>