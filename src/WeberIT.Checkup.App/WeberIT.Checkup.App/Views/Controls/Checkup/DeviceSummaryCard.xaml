<UserControl x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.DeviceSummaryCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource PanelCardStyle}">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Markanter Gerätebereich -->

            <Border
                Grid.Column="0"
                Padding="24"
                Background="{StaticResource PrimaryBrush}"
                CornerRadius="10">

                <StackPanel>

                    <Border
                        Width="56"
                        Height="56"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SecondaryBrush}"
                        CornerRadius="12">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI Emoji"
                            FontSize="28"
                            Foreground="{StaticResource SurfaceBrush}"
                            Text="🖥" />

                    </Border>

                    <TextBlock
                        Margin="0,24,0,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource BorderBrush}"
                        Text="GERÄT"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SurfaceBrush}"
                        Text="{Binding DeviceInformation.Name}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="15"
                        Foreground="{StaticResource BorderBrush}"
                        Text="{Binding DeviceInformation.DeviceType}"
                        TextWrapping="Wrap" />

                    <Border
                        Margin="0,24,0,0"
                        Padding="12,8"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SecondaryBrush}"
                        CornerRadius="8">

                        <TextBlock
                            Foreground="{StaticResource SurfaceBrush}"
                            Text="{Binding OperatingSystemInformation.Name}"
                            TextWrapping="Wrap" />

                    </Border>

                </StackPanel>

            </Border>

            <!-- Systemübersicht -->

            <StackPanel Grid.Column="2">

                <TextBlock
                    Text="Systemübersicht"
                    Style="{StaticResource SectionTitleTextStyle}" />

                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Die wichtigsten Geräteinformationen auf einen Blick."
                    TextWrapping="Wrap" />

                <Grid Margin="0,24,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Hersteller -->

                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="HERSTELLER" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding DeviceInformation.Manufacturer}"
                                TextWrapping="Wrap" />

                        </StackPanel>

                    </Border>

                    <!-- Modell -->

                    <Border
                        Grid.Row="0"
                        Grid.Column="2"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="MODELL" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding DeviceInformation.Model}"
                                TextWrapping="Wrap" />

                        </StackPanel>

                    </Border>

                    <!-- Windows -->

                    <Border
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="BETRIEBSSYSTEM" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding OperatingSystemInformation.Name}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}">

                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Version {0} · Build {1}">
                                        <Binding Path="OperatingSystemInformation.Version" />
                                        <Binding Path="OperatingSystemInformation.BuildNumber" />
                                    </MultiBinding>
                                </TextBlock.Text>

                            </TextBlock>

                        </StackPanel>

                    </Border>

                    <!-- Scanzeit -->

                    <Border
                        Grid.Row="2"
                        Grid.Column="2"
                        Padding="16"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>

                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="LETZTER SCAN" />

                            <TextBlock
                                Margin="0,8,0,0"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}">

                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:dd.MM.yyyy}">
                                        <Binding Path="ScanDate" />
                                    </MultiBinding>
                                </TextBlock.Text>

                            </TextBlock>

                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}">

                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:HH:mm} Uhr">
                                        <Binding Path="ScanDate" />
                                    </MultiBinding>
                                </TextBlock.Text>

                            </TextBlock>

                        </StackPanel>

                    </Border>

                </Grid>

                <Border
                    Margin="0,16,0,0"
                    Padding="16,12"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Seriennummer" />

                        <TextBlock
                            Grid.Column="1"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding DeviceInformation.SerialNumber}"
                            TextWrapping="Wrap" />

                    </Grid>

                </Border>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>