<UserControl
    x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.PhysicalDriveInformationCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Margin="0,0,0,12"
        Padding="16"
        Background="{StaticResource BackgroundBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="8">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{Binding Model}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="{Binding DiskNumberText}"
                        TextWrapping="Wrap" />

                </StackPanel>

                <Border
                    Grid.Column="1"
                    Margin="20,0,0,0"
                    Padding="10,6"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="6">

                    <Border.Style>

                        <Style TargetType="Border">

                            <Setter
                                Property="BorderBrush"
                                Value="{StaticResource BorderBrush}" />

                            <Style.Triggers>

                                <DataTrigger
                                    Binding="{Binding HealthStatus}"
                                    Value="Healthy">

                                    <Setter
                                        Property="BorderBrush"
                                        Value="{StaticResource SuccessBrush}" />

                                </DataTrigger>

                                <DataTrigger
                                    Binding="{Binding HealthStatus}"
                                    Value="Warning">

                                    <Setter
                                        Property="BorderBrush"
                                        Value="{StaticResource WarningBrush}" />

                                </DataTrigger>

                                <DataTrigger
                                    Binding="{Binding HealthStatus}"
                                    Value="Critical">

                                    <Setter
                                        Property="BorderBrush"
                                        Value="{StaticResource DangerBrush}" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Border.Style>

                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{Binding HealthStatusText}" />

                </Border>

            </Grid>

            <Grid Margin="0,18,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontWeight="SemiBold"
                    Text="Kapazität:" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="{Binding Capacity}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="20,0,0,0"
                    FontWeight="SemiBold"
                    Text="Laufwerksart:" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="3"
                    Text="{Binding DriveType}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,10,0,0"
                    FontWeight="SemiBold"
                    Text="Medientyp:" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,10,0,0"
                    Text="{Binding MediaTypeText}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="20,10,0,0"
                    FontWeight="SemiBold"
                    Text="Anbindung:" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="3"
                    Margin="0,10,0,0"
                    Text="{Binding BusTypeText}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,10,0,0"
                    FontWeight="SemiBold"
                    Text="Rolle:" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Grid.ColumnSpan="3"
                    Margin="0,10,0,0"
                    Text="{Binding RoleText}"
                    TextWrapping="Wrap" />

            </Grid>

            <Border
                Margin="0,16,0,0"
                Padding="12"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">

                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding HealthDetails}"
                    TextWrapping="Wrap" />

            </Border>

            <TextBlock
                Margin="0,12,0,0"
                FontSize="11"
                Foreground="{StaticResource TextMutedBrush}"
                Text="Der Windows-Gesundheitsstatus ist eine lokale Treiberaussage und keine garantierte Restlebensdauer."
                TextWrapping="Wrap" />

        </StackPanel>

    </Border>

</UserControl>