<UserControl
    x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.CheckupDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:checkup="clr-namespace:WeberIT.Checkup.App.Views.Controls.Checkup"
    xmlns:converters="clr-namespace:WeberIT.Checkup.App.Infrastructure.Converters">

    <UserControl.Resources>

        <converters:FindingSeverityToSymbolConverter
            x:Key="FindingSeverityToSymbolConverter" />

    </UserControl.Resources>

    <StackPanel>

        <checkup:DeviceSummaryCard />

        <Grid Margin="0,24,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Linke Spalte -->

            <StackPanel Grid.Column="0">

                <!-- Hardware -->

                <Border Style="{StaticResource PanelCardStyle}">

                    <StackPanel>

                        <TextBlock
                            Text="Hardware"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <Grid Margin="0,18,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                FontWeight="SemiBold"
                                Text="Prozessor:" />

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding HardwareInformation.ProcessorName}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="Arbeitsspeicher:" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding HardwareInformation.InstalledMemory}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="Mainboard-Hersteller:" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding HardwareInformation.MainboardManufacturer}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="Mainboard-Modell:" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding HardwareInformation.MainboardProduct}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="BIOS-Hersteller:" />

                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding HardwareInformation.BiosManufacturer}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="BIOS-Version:" />

                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding HardwareInformation.BiosVersion}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="TPM-Status:" />

                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding HardwareInformation.TpmStatus}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="TPM-Version:" />

                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding HardwareInformation.TpmVersion}"
                                TextWrapping="Wrap" />

                        </Grid>

                        <TextBlock
                            Margin="0,24,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Grafikkarten" />

                        <ItemsControl
                            Margin="0,8,0,0"
                            ItemsSource="{Binding HardwareInformation.GraphicsCards}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">

                                        <TextBlock
                                            Text="{Binding}"
                                            TextWrapping="Wrap" />

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </StackPanel>

                </Border>

                <!-- Datenträger -->

                <Border
                    Margin="0,24,0,0"
                    Style="{StaticResource PanelCardStyle}">

                    <StackPanel>

                        <TextBlock
                            Text="Datenträger"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Physische Datenträger und zugehörige Windows-Volumes des gescannten Systems."
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,20,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Physische Laufwerke" />

                        <ItemsControl
                            Margin="0,10,0,0"
                            ItemsSource="{Binding StorageInformation.PhysicalDrives}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <checkup:PhysicalDriveInformationCard />

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                        <TextBlock
                            Margin="0,20,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Volumes / Laufwerksbuchstaben" />

                        <ItemsControl
                            Margin="0,10,0,0"
                            ItemsSource="{Binding StorageInformation.Volumes}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="14"
                                        Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Grid.Column="0"
                                                FontWeight="SemiBold"
                                                Text="{Binding DriveLetter}" />

                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="16,0,0,0"
                                                Text="{Binding DriveType}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="16,0,0,0"
                                                Text="{Binding FileSystem}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Grid.Column="3"
                                                Margin="16,0,0,0"
                                                Text="{Binding TotalSize}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Grid.Column="4"
                                                Margin="16,0,0,0"
                                                Text="{Binding FreeSpace}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Grid.Column="5"
                                                Margin="16,0,0,0"
                                                Text="{Binding IsReady}" />

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </StackPanel>

                </Border>

                <!-- System / Software -->

                <Border
                    Margin="0,24,0,0"
                    Style="{StaticResource PanelCardStyle}">

                    <StackPanel>

                        <TextBlock
                            Text="System / Software"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <Grid Margin="0,18,0,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                FontWeight="SemiBold"
                                Text="Windows:" />

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding OperatingSystemInformation.Name}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="Version:" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding OperatingSystemInformation.Version}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="Build:" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding OperatingSystemInformation.BuildNumber}" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,10,0,0"
                                FontWeight="SemiBold"
                                Text="Architektur:" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="0,10,0,0"
                                Text="{Binding OperatingSystemInformation.Architecture}" />

                        </Grid>

                    </StackPanel>

                </Border>

            </StackPanel>

            <!-- Rechte Spalte -->

            <StackPanel Grid.Column="2">

                <!-- Bewertung -->

                <Border Style="{StaticResource PanelCardStyle}">

                    <StackPanel>

                        <TextBlock
                            Text="Bewertung"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,8,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Empfehlungen, Warnungen und kritische Befunde stehen im Vordergrund. Reine Informationsbefunde sind kompakt eingeklappt."
                            TextWrapping="Wrap" />

                        <Border
                            Margin="0,16,0,0"
                            Padding="12,9"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="7">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="14"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="&#xE9D9;" />

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding Assessment.FindingsOverviewText}"
                                    TextWrapping="Wrap" />

                            </Grid>

                        </Border>

                        <Border
                            Margin="0,16,0,0"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource SuccessBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Border.Style>

                                <Style TargetType="Border">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding Assessment.HasActionableFindings}"
                                            Value="False">

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </Border.Style>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Top"
                                    FontSize="18"
                                    Foreground="{StaticResource SuccessBrush}"
                                    Text="✓" />

                                <StackPanel Grid.Column="1">

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Kein unmittelbarer Handlungsbedarf erkannt"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,5,0,0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Die Bewertung enthält derzeit keine Empfehlung, Warnung oder kritische Auffälligkeit."
                                        TextWrapping="Wrap" />

                                </StackPanel>

                            </Grid>

                        </Border>

                        <ItemsControl
                            Margin="0,20,0,0"
                            ItemsSource="{Binding Assessment.ActionableFindings}">

                            <ItemsControl.Style>

                                <Style TargetType="ItemsControl">

                                    <Setter
                                        Property="Visibility"
                                        Value="Visible" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding Assessment.HasActionableFindings}"
                                            Value="False">

                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </ItemsControl.Style>

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="14"
                                        Background="{StaticResource BackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Top"
                                                FontSize="18"
                                                Text="{Binding Severity, Converter={StaticResource FindingSeverityToSymbolConverter}}" />

                                            <StackPanel Grid.Column="1">

                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    Text="{Binding Title}"
                                                    TextWrapping="Wrap" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding Description}"
                                                    TextWrapping="Wrap" />

                                            </StackPanel>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                        <Expander
                            Margin="0,4,0,0"
                            IsExpanded="False">

                            <Expander.Style>

                                <Style TargetType="Expander">

                                    <Setter
                                        Property="Visibility"
                                        Value="Visible" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding Assessment.HasInformationalFindings}"
                                            Value="False">

                                            <Setter
                                                Property="Visibility"
                                                Value="Collapsed" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </Expander.Style>

                            <Expander.Header>

                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding Assessment.InformationalFindingsHeaderText}" />

                            </Expander.Header>

                            <ItemsControl
                                Margin="0,10,0,0"
                                ItemsSource="{Binding Assessment.InformationalFindings}">

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="10"
                                            Background="{StaticResource SurfaceSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">

                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Top"
                                                    FontSize="14"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    Text="{Binding Severity, Converter={StaticResource FindingSeverityToSymbolConverter}}" />

                                                <StackPanel Grid.Column="1">

                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Text="{Binding Title}"
                                                        TextWrapping="Wrap" />

                                                    <TextBlock
                                                        Margin="0,3,0,0"
                                                        FontSize="11"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        Text="{Binding Description}"
                                                        TextWrapping="Wrap" />

                                                </StackPanel>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </Expander>

                    </StackPanel>

                </Border>

            </StackPanel>

        </Grid>

        <checkup:RestartInformationCard
            Margin="0,24,0,0"
            DataContext="{Binding RestartInformation}" />

        <checkup:CleanupPotentialCard
            Margin="0,24,0,0"
            DataContext="{Binding CleanupPotentialInformation}" />

        <checkup:StartupInformationCard
            Margin="0,24,0,0"
            DataContext="{Binding StartupInformation}" />

        <checkup:DeviceDriverInformationCard
            Margin="0,24,0,0"
            DataContext="{Binding DeviceDriverInformation}" />

    </StackPanel>

</UserControl>