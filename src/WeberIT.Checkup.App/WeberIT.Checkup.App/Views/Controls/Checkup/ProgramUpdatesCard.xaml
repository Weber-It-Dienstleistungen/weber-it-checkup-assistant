<UserControl x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.ProgramUpdatesCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource PanelCardStyle}">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        Text="Programmaktualisierungen"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Über die öffentliche WinGet-Quelle erkannte Programmaktualisierungen."
                        TextWrapping="Wrap" />

                </StackPanel>

                <Border
                    Grid.Column="1"
                    Margin="20,0,0,0"
                    Padding="12,7"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="7">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock
                            Margin="0,0,5,0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="Aktualisierungen:" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding AvailableUpdateCount}" />

                    </StackPanel>

                </Border>

            </Grid>

            <Grid Margin="0,20,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontWeight="SemiBold"
                    Text="WinGet verfügbar:" />

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="{Binding IsWingetAvailable}" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,8,0,0"
                    FontWeight="SemiBold"
                    Text="WinGet-Version:" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,8,0,0"
                    Text="{Binding WingetVersion}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,8,0,0"
                    FontWeight="SemiBold"
                    Text="Analysezeitpunkt:" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,8,0,0"
                    Text="{Binding AnalysisDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" />

            </Grid>

            <Border
                Margin="0,18,0,0"
                Padding="12"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="7">

                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{Binding AnalysisDetails}"
                    TextWrapping="Wrap" />

            </Border>

            <TextBlock
                Margin="0,22,0,10"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Erkannte Aktualisierungen" />

            <TextBlock
                Foreground="{StaticResource TextMutedBrush}"
                Text="Keine Programmliste verfügbar."
                TextWrapping="Wrap">

                <TextBlock.Style>

                    <Style TargetType="TextBlock">

                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>

                            <DataTrigger
                                Binding="{Binding AvailableUpdateCount}"
                                Value="0">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </TextBlock.Style>

            </TextBlock>

            <ItemsControl
                ItemsSource="{Binding AvailableUpdates}">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Margin="0,0,0,10"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding Name}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="Programm" />

                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Margin="20,0,0,0">

                                    <TextBlock
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding PackageId}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="Paket-ID" />

                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    Margin="20,0,0,0">

                                    <TextBlock
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding InstalledVersion}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="Installiert" />

                                </StackPanel>

                                <TextBlock
                                    Grid.Column="3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    FontSize="16"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="→" />

                                <StackPanel Grid.Column="4">

                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource AccentBrush}"
                                        Text="{Binding AvailableVersion}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="Verfügbar" />

                                </StackPanel>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <Border
                Margin="0,8,0,0"
                Padding="12"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource InformationBrush}"
                BorderThickness="1"
                CornerRadius="7">

                <Border.Style>

                    <Style
                        TargetType="Border"
                        BasedOn="{StaticResource PanelCardStyle}">

                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>

                            <DataTrigger
                                Binding="{Binding IsResultTruncated}"
                                Value="True">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Border.Style>

                <TextBlock
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Die gespeicherte Programmliste wurde aus Speicher- und Darstellungsgründen begrenzt."
                    TextWrapping="Wrap" />

            </Border>

            <TextBlock
                Margin="0,14,0,0"
                FontSize="11"
                Foreground="{StaticResource TextMutedBrush}"
                Text="Microsoft-Store-Apps und Programme, die WinGet nicht zuordnen kann, sind in dieser Liste nicht enthalten. Es wurden keine Programme aktualisiert."
                TextWrapping="Wrap" />

        </StackPanel>

    </Border>

</UserControl>