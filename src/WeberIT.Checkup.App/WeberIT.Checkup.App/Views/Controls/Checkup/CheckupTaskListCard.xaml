<UserControl
    x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.CheckupTaskListCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:WeberIT.Checkup.App.Infrastructure.Converters"
    xmlns:models="clr-namespace:WeberIT.Checkup.App.Models">

    <UserControl.Resources>
        <converters:TaskCodeToActionDefinitionConverter
            x:Key="TaskCodeToActionDefinitionConverter" />
    </UserControl.Resources>

    <Border Style="{StaticResource PanelCardStyle}">
        <StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        Text="Geführte Aufgabenliste"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Aus den prüfungsrelevanten Befunden abgeleitete Arbeitspositionen. Die Aufgabenliste ist vom System- und Hardwarezustand getrennt."
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Margin="24,0,0,0"
                    Padding="12,7"
                    VerticalAlignment="Top"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="7">

                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{Binding VersionText}" />
                </Border>
            </Grid>

            <!-- Historischer Checkup -->

            <Border
                Margin="0,20,0,0"
                Padding="16"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter
                            Property="Visibility"
                            Value="Visible" />

                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsAvailable}"
                                Value="True">

                                <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="17"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="&#xE823;" />

                    <StackPanel Grid.Column="1">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Keine Aufgabenliste enthalten" />

                        <TextBlock
                            Margin="0,5,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding AvailabilityText}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="Für eine aktuelle Aufgabenableitung ist ein neuer Systemscan erforderlich."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Neuer Checkup ohne Aufgaben -->

            <Border
                Margin="0,20,0,0"
                Padding="16"
                Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource SuccessBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition
                                        Binding="{Binding IsAvailable}"
                                        Value="True" />

                                    <Condition
                                        Binding="{Binding HasTasks}"
                                        Value="False" />
                                </MultiDataTrigger.Conditions>

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="17"
                        Foreground="{StaticResource SuccessBrush}"
                        Text="&#xE73E;" />

                    <StackPanel Grid.Column="1">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Keine Aufgaben abgeleitet" />

                        <TextBlock
                            Margin="0,5,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding AvailabilityText}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="Nicht auswertbare Bereiche und reine Informationen erzeugen keine künstlichen Aufgaben."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Zusammenfassung -->

            <Grid Margin="0,20,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding HasTasks}"
                                Value="True">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="14"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="GESAMT" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{Binding TotalTaskCount}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="14"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="OFFEN" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="{Binding OpenTaskCount}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="4"
                    Padding="14"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource WarningBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="PFLICHT OFFEN" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource WarningBrush}"
                            Text="{Binding RequiredOpenTaskCount}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="6"
                    Padding="14"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource SuccessBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="DOKUMENTIERT" />

                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SuccessBrush}"
                            Text="{Binding DocumentedTaskCount}" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock
                Margin="0,12,0,0"
                FontSize="12"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{Binding ProgressText}"
                TextWrapping="Wrap">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding HasTasks}"
                                Value="True">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Aufgaben -->

            <ItemsControl
                Margin="0,18,0,0"
                ItemsSource="{Binding Tasks}">

                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding HasTasks}"
                                Value="True">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="30"
                                    Height="30"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    CornerRadius="15">

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="14"
                                        Text="&#xE7BA;">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter
                                                    Property="Foreground"
                                                    Value="{StaticResource InformationBrush}" />

                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding Priority}"
                                                        Value="{x:Static models:CheckupTaskPriority.Recommended}">

                                                        <Setter
                                                            Property="Foreground"
                                                            Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>

                                                    <DataTrigger
                                                        Binding="{Binding Priority}"
                                                        Value="{x:Static models:CheckupTaskPriority.Required}">

                                                        <Setter
                                                            Property="Foreground"
                                                            Value="{StaticResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Border
                                            Margin="0,0,8,0"
                                            Padding="8,3"
                                            Background="{StaticResource SurfaceSecondaryBrush}"
                                            CornerRadius="5">

                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Text="{Binding PriorityText}">

                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter
                                                            Property="Foreground"
                                                            Value="{StaticResource InformationBrush}" />

                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                Binding="{Binding Priority}"
                                                                Value="{x:Static models:CheckupTaskPriority.Recommended}">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource AccentBrush}" />
                                                            </DataTrigger>

                                                            <DataTrigger
                                                                Binding="{Binding Priority}"
                                                                Value="{x:Static models:CheckupTaskPriority.Required}">

                                                                <Setter
                                                                    Property="Foreground"
                                                                    Value="{StaticResource WarningBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <Border
                                            Padding="8,3"
                                            Background="{StaticResource SurfaceSecondaryBrush}"
                                            CornerRadius="5">

                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding CategoryText}" />
                                        </Border>
                                    </StackPanel>

                                    <TextBlock
                                        Margin="0,9,0,0"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{Binding Title}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap" />

                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="12"
                                        Background="{StaticResource SurfaceSecondaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        DataContext="{Binding TaskCode, Converter={StaticResource TaskCodeToActionDefinitionConverter}}">

                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    Text="{Binding AvailabilityText}" />

                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="16,0,0,0"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding RiskLevelText}" />
                                            </Grid>

                                            <TextBlock
                                                Margin="0,6,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource AccentBrush}"
                                                Text="{Binding ActionTitle}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Margin="0,5,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding Description}"
                                                TextWrapping="Wrap" />

                                            <TextBlock
                                                Margin="0,5,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                Text="{Binding RiskDescription}"
                                                TextWrapping="Wrap" />

                                            <StackPanel
                                                Margin="0,10,0,0"
                                                Orientation="Horizontal">

                                                <Button
                                                    Content="Aktionsdetails anzeigen"
                                                    Click="ActionDetailsButton_OnClick" />

                                                <Button
                                                    Margin="8,0,0,0"
                                                    CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                    Content="Programmupdates auswählen"
                                                    Click="ProgramUpdateSelectionButton_OnClick">

                                                    <Button.Style>
                                                        <Style
                                                            BasedOn="{StaticResource {x:Type Button}}"
                                                            TargetType="Button">

                                                            <Setter
                                                                Property="Visibility"
                                                                Value="Collapsed" />

                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding ActionCode}"
                                                                    Value="action.program-updates.selected-upgrades">

                                                                    <Setter
                                                                        Property="Visibility"
                                                                        Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="12"
                                        Background="{StaticResource SurfaceSecondaryBrush}"
                                        BorderBrush="{StaticResource InformationBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter
                                                    Property="Visibility"
                                                    Value="Collapsed" />

                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding HasActionResults}"
                                                        Value="True">

                                                        <Setter
                                                            Property="Visibility"
                                                            Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource InformationBrush}"
                                                Text="{Binding ActionProgressText}" />

                                            <ItemsControl
                                                Margin="0,8,0,0"
                                                ItemsSource="{Binding ActionResults}">

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            Margin="0,0,0,8"
                                                            Padding="10"
                                                            Background="{StaticResource BackgroundBrush}"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="5">

                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock
                                                                        Grid.Column="0"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                                        Text="{Binding ActionTitle}"
                                                                        TextWrapping="Wrap" />

                                                                    <TextBlock
                                                                        Grid.Column="1"
                                                                        Margin="16,0,0,0"
                                                                        FontSize="10"
                                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                                        Text="{Binding StatusText}" />
                                                                </Grid>

                                                                <TextBlock
                                                                    Margin="0,5,0,0"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                                    Text="{Binding TargetDescription}"
                                                                    TextWrapping="Wrap" />

                                                                <TextBlock
                                                                    Margin="0,5,0,0"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                                    Text="{Binding Summary}"
                                                                    TextWrapping="Wrap" />

                                                                <TextBlock
                                                                    Margin="0,5,0,0"
                                                                    FontSize="10"
                                                                    Foreground="{StaticResource TextMutedBrush}"
                                                                    Text="{Binding FinishedAtText}"
                                                                    TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Border
                                    Grid.Column="2"
                                    Margin="20,0,0,0"
                                    Padding="9,5"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource SurfaceSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5">

                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding StatusText}" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Margin="0,2,0,0"
                FontSize="11"
                Foreground="{StaticResource TextMutedBrush}"
                Text="In dieser Ausbaustufe werden Aktionsart und mögliche Risiken nur angezeigt. Aus der Aufgabenkarte wird noch keine Reparatur, Installation, Aktualisierung oder sonstige Systemänderung gestartet."
                TextWrapping="Wrap">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter
                            Property="Visibility"
                            Value="Collapsed" />

                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding HasTasks}"
                                Value="True">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>