<UserControl
    x:Class="WeberIT.Checkup.App.Views.Controls.Checkup.CheckupTaskStatusEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:WeberIT.Checkup.App.Models">

    <UserControl.Resources>

        <Style
            x:Key="TaskEditorListBoxItemStyle"
            TargetType="ListBoxItem">

            <Setter
                Property="Margin"
                Value="0,0,0,6" />

            <Setter
                Property="Padding"
                Value="12,9" />

            <Setter
                Property="Background"
                Value="{StaticResource BackgroundBrush}" />

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource BorderBrush}" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="HorizontalContentAlignment"
                Value="Stretch" />

            <Style.Triggers>

                <Trigger
                    Property="IsMouseOver"
                    Value="True">

                    <Setter
                        Property="BorderBrush"
                        Value="{StaticResource AccentBrush}" />

                    <Setter
                        Property="Background"
                        Value="{StaticResource SurfaceSecondaryBrush}" />

                </Trigger>

                <Trigger
                    Property="IsSelected"
                    Value="True">

                    <Setter
                        Property="BorderBrush"
                        Value="{StaticResource AccentBrush}" />

                    <Setter
                        Property="Background"
                        Value="{StaticResource AccentBrush}" />

                    <Setter
                        Property="Foreground"
                        Value="White" />

                </Trigger>

            </Style.Triggers>

        </Style>

        <Style
            x:Key="TaskEditorRadioButtonStyle"
            TargetType="RadioButton">

            <Setter
                Property="Margin"
                Value="0,0,0,8" />

            <Setter
                Property="Padding"
                Value="6,4" />

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="FontSize"
                Value="13" />

            <Setter
                Property="VerticalContentAlignment"
                Value="Center" />

        </Style>

        <Style
            x:Key="TaskEditorTextBoxStyle"
            TargetType="TextBox">

            <Setter
                Property="MinHeight"
                Value="72" />

            <Setter
                Property="Padding"
                Value="10,8" />

            <Setter
                Property="Background"
                Value="{StaticResource BackgroundBrush}" />

            <Setter
                Property="Foreground"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="CaretBrush"
                Value="{StaticResource TextPrimaryBrush}" />

            <Setter
                Property="SelectionBrush"
                Value="{StaticResource AccentBrush}" />

            <Setter
                Property="BorderBrush"
                Value="{StaticResource BorderBrush}" />

            <Setter
                Property="BorderThickness"
                Value="1" />

            <Setter
                Property="AcceptsReturn"
                Value="True" />

            <Setter
                Property="TextWrapping"
                Value="Wrap" />

            <Setter
                Property="VerticalContentAlignment"
                Value="Top" />

            <Setter
                Property="VerticalScrollBarVisibility"
                Value="Auto" />

            <Style.Triggers>

                <Trigger
                    Property="IsKeyboardFocusWithin"
                    Value="True">

                    <Setter
                        Property="BorderBrush"
                        Value="{StaticResource AccentBrush}" />

                </Trigger>

                <Trigger
                    Property="IsMouseOver"
                    Value="True">

                    <Setter
                        Property="BorderBrush"
                        Value="{StaticResource TextMutedBrush}" />

                </Trigger>

            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Border
        Padding="18"
        Background="{StaticResource SurfaceSecondaryBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="8">

        <Border.Style>

            <Style TargetType="Border">

                <Setter
                    Property="Visibility"
                    Value="Collapsed" />

                <Style.Triggers>

                    <DataTrigger
                        Binding="{Binding HasTasks}"
                        Value="True">

                        <Setter
                            Property="Visibility"
                            Value="Visible" />

                    </DataTrigger>

                </Style.Triggers>

            </Style>

        </Border.Style>

        <StackPanel>

            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Aufgabenstatus dokumentieren" />

            <TextBlock
                Margin="0,5,0,0"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="Eine Statusänderung benötigt immer eine nachvollziehbare Begründung. In diesem Schritt wird die Änderung noch nicht dauerhaft gespeichert."
                TextWrapping="Wrap" />

            <Grid Margin="0,18,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <!-- Aufgabenauswahl -->

                <StackPanel Grid.Column="0">

                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="AUFGABE AUSWÄHLEN" />

                    <ListBox
                        x:Name="TaskListBox"
                        Margin="0,7,0,0"
                        MaxHeight="190"
                        Padding="6"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        ItemContainerStyle="{StaticResource TaskEditorListBoxItemStyle}"
                        ItemsSource="{Binding Tasks}"
                        SelectionChanged="TaskListBox_OnSelectionChanged"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <ListBox.ItemTemplate>

                            <DataTemplate>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">

                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                            Text="{Binding Title}"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Margin="0,3,0,0"
                                            FontSize="11"
                                            Foreground="{StaticResource TextSecondaryBrush}">

                                            <TextBlock.Text>

                                                <MultiBinding StringFormat="{}{0} · {1}">
                                                    <Binding Path="PriorityText" />
                                                    <Binding Path="CategoryText" />
                                                </MultiBinding>

                                            </TextBlock.Text>

                                            <TextBlock.Style>

                                                <Style TargetType="TextBlock">

                                                    <Setter
                                                        Property="Opacity"
                                                        Value="1" />

                                                    <Style.Triggers>

                                                        <DataTrigger
                                                            Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                            Value="True">

                                                            <Setter
                                                                Property="Foreground"
                                                                Value="White" />

                                                            <Setter
                                                                Property="Opacity"
                                                                Value="0.85" />

                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>

                                            </TextBlock.Style>

                                        </TextBlock>

                                    </StackPanel>

                                    <Border
                                        Grid.Column="1"
                                        Margin="14,0,0,0"
                                        Padding="8,4"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource SurfaceSecondaryBrush}"
                                        CornerRadius="5">

                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{Binding StatusText}" />

                                    </Border>

                                </Grid>

                            </DataTemplate>

                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>

                <!-- Statusauswahl -->

                <StackPanel Grid.Column="2">

                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="NEUER STATUS" />

                    <Border
                        Margin="0,7,0,0"
                        Padding="14"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="7">

                        <StackPanel x:Name="StatusOptionsPanel">

                            <RadioButton
                                Content="Offen"
                                GroupName="TaskStatus"
                                Style="{StaticResource TaskEditorRadioButtonStyle}"
                                Tag="{x:Static models:CheckupTaskStatus.Open}" />

                            <RadioButton
                                Content="Erledigt"
                                GroupName="TaskStatus"
                                Style="{StaticResource TaskEditorRadioButtonStyle}"
                                Tag="{x:Static models:CheckupTaskStatus.Completed}" />

                            <RadioButton
                                Content="Übersprungen"
                                GroupName="TaskStatus"
                                Style="{StaticResource TaskEditorRadioButtonStyle}"
                                Tag="{x:Static models:CheckupTaskStatus.Skipped}" />

                            <RadioButton
                                Margin="0"
                                Content="Nicht durchführbar"
                                GroupName="TaskStatus"
                                Style="{StaticResource TaskEditorRadioButtonStyle}"
                                Tag="{x:Static models:CheckupTaskStatus.NotFeasible}" />

                        </StackPanel>

                    </Border>

                </StackPanel>

            </Grid>

            <TextBlock
                Margin="0,18,0,0"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="BEGRÜNDUNG – PFLICHTFELD" />

            <TextBox
                x:Name="StatusReasonTextBox"
                Margin="0,6,0,0"
                Style="{StaticResource TaskEditorTextBoxStyle}" />

            <TextBlock
                Margin="0,18,0,0"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="TECHNIKERNOTIZ – OPTIONAL" />

            <TextBox
                x:Name="TechnicianNoteTextBox"
                Margin="0,6,0,0"
                Style="{StaticResource TaskEditorTextBoxStyle}" />

            <Grid Margin="0,18,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="ValidationTextBlock"
                    Grid.Column="0"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource WarningBrush}"
                    TextWrapping="Wrap" />

                <Button
                    Grid.Column="1"
                    Width="190"
                    Height="38"
                    Click="ApplyStatusButton_OnClick"
                    Content="Status übernehmen"
                    Style="{StaticResource AccentButtonStyle}" />

            </Grid>

        </StackPanel>

    </Border>

</UserControl>