<UserControl x:Class="WeberIT.Checkup.App.Views.Controls.CustomerDevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:checkup="clr-namespace:WeberIT.Checkup.App.Views.Controls.Checkup">

    <Border
        Style="{StaticResource PanelCardStyle}"
        Padding="24"
        BorderBrush="{StaticResource AccentBrush}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Kopfbereich -->

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <StackPanel Orientation="Horizontal">

                        <Border
                            Width="36"
                            Height="36"
                            Margin="0,0,12,0"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="8">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="17"
                                Foreground="{StaticResource AccentBrush}"
                                Text="&#xE7F8;" />

                        </Border>

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock
                                Text="Geräte und Systemchecks"
                                Style="{StaticResource SectionTitleTextStyle}" />

                            <TextBlock
                                Margin="0,3,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding DeviceCountText}" />

                        </StackPanel>

                    </StackPanel>

                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="125"
                    VerticalAlignment="Center"
                    Content="Neu scannen"
                    Command="{Binding RescanDeviceCommand}" />

                <Button
                    Grid.Column="3"
                    Width="105"
                    VerticalAlignment="Center"
                    Content="Löschen"
                    Command="{Binding DeleteDeviceCommand}"
                    Foreground="{StaticResource DangerBrush}" />

                <Button
                    Grid.Column="5"
                    Width="150"
                    VerticalAlignment="Center"
                    Content="Gerät hinzufügen"
                    Command="{Binding AddDeviceCommand}"
                    Style="{StaticResource AccentButtonStyle}" />

            </Grid>

            <!-- Geräteliste -->

            <Grid Grid.Row="2">

                <Border
                    Padding="18"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                        <Border
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            Background="{StaticResource BackgroundBrush}"
                            CornerRadius="24">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="20"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="&#xE7F8;" />

                        </Border>

                        <TextBlock
                            Margin="0,12,0,0"
                            HorizontalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Noch kein Gerät gespeichert" />

                        <TextBlock
                            Margin="0,5,0,0"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Fügen Sie ein Gerät hinzu, um einen ersten Systemscan zu speichern."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                    </StackPanel>

                    <Border.Style>

                        <Style TargetType="Border">

                            <Setter
                                Property="Visibility"
                                Value="Collapsed" />

                            <Style.Triggers>

                                <DataTrigger
                                    Binding="{Binding SelectedCustomer.Devices.Count}"
                                    Value="0">

                                    <Setter
                                        Property="Visibility"
                                        Value="Visible" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Border.Style>

                </Border>

                <ListBox
                    ItemsSource="{Binding Devices}"
                    SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                    Background="Transparent"
                    BorderThickness="0"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.Style>

                        <Style
                            TargetType="ListBox"
                            BasedOn="{StaticResource {x:Type ListBox}}">

                            <Setter
                                Property="Visibility"
                                Value="Visible" />

                            <Style.Triggers>

                                <DataTrigger
                                    Binding="{Binding SelectedCustomer.Devices.Count}"
                                    Value="0">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </ListBox.Style>

                    <ListBox.ItemsPanel>

                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>

                    </ListBox.ItemsPanel>

                    <ListBox.ItemContainerStyle>

                        <Style
                            TargetType="ListBoxItem"
                            BasedOn="{StaticResource {x:Type ListBoxItem}}">

                            <Setter
                                Property="Width"
                                Value="270" />

                            <Setter
                                Property="Margin"
                                Value="0,0,12,12" />

                            <Setter
                                Property="VerticalContentAlignment"
                                Value="Stretch" />

                        </Style>

                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Border
                                MinHeight="122"
                                Padding="15"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9">

                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Grid.Column="0"
                                            Width="28"
                                            Height="28"
                                            VerticalAlignment="Top"
                                            Background="{StaticResource BackgroundBrush}"
                                            CornerRadius="6">

                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="13"
                                                Foreground="{StaticResource AccentBrush}"
                                                Text="&#xE7F8;" />

                                        </Border>

                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{Binding DisplayName}"
                                            TextTrimming="CharacterEllipsis" />

                                    </Grid>

                                    <StackPanel
                                        Grid.Row="1"
                                        Margin="36,8,0,0"
                                        Orientation="Horizontal">

                                        <StackPanel.Style>

                                            <Style TargetType="StackPanel">

                                                <Setter
                                                    Property="Visibility"
                                                    Value="Visible" />

                                                <Style.Triggers>

                                                    <MultiDataTrigger>

                                                        <MultiDataTrigger.Conditions>

                                                            <Condition
                                                                Binding="{Binding CheckupSession.DeviceInformation.Manufacturer}"
                                                                Value="{x:Static sys:String.Empty}" />

                                                            <Condition
                                                                Binding="{Binding CheckupSession.DeviceInformation.Model}"
                                                                Value="{x:Static sys:String.Empty}" />

                                                        </MultiDataTrigger.Conditions>

                                                        <Setter
                                                            Property="Visibility"
                                                            Value="Collapsed" />

                                                    </MultiDataTrigger>

                                                </Style.Triggers>

                                            </Style>

                                        </StackPanel.Style>

                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding CheckupSession.DeviceInformation.Manufacturer}"
                                            TextTrimming="CharacterEllipsis" />

                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text=" · ">

                                            <TextBlock.Style>

                                                <Style TargetType="TextBlock">

                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Visible" />

                                                    <Style.Triggers>

                                                        <DataTrigger
                                                            Binding="{Binding CheckupSession.DeviceInformation.Manufacturer}"
                                                            Value="{x:Static sys:String.Empty}">

                                                            <Setter
                                                                Property="Visibility"
                                                                Value="Collapsed" />

                                                        </DataTrigger>

                                                        <DataTrigger
                                                            Binding="{Binding CheckupSession.DeviceInformation.Model}"
                                                            Value="{x:Static sys:String.Empty}">

                                                            <Setter
                                                                Property="Visibility"
                                                                Value="Collapsed" />

                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>

                                            </TextBlock.Style>

                                        </TextBlock>

                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{Binding CheckupSession.DeviceInformation.Model}"
                                            TextTrimming="CharacterEllipsis" />

                                    </StackPanel>

                                    <Border
                                        Grid.Row="3"
                                        Margin="36,12,0,0"
                                        Padding="8,4"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource BackgroundBrush}"
                                        CornerRadius="5">

                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{StaticResource TextMutedBrush}">

                                            <TextBlock.Text>

                                                <MultiBinding StringFormat="{}Scan: {0:dd.MM.yyyy HH:mm}">
                                                    <Binding Path="CheckupSession.ScanDate" />
                                                </MultiBinding>

                                            </TextBlock.Text>

                                        </TextBlock>

                                    </Border>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

            </Grid>

            <!-- Hinweis ohne Geräteauswahl -->

            <Border
                Grid.Row="4"
                Padding="18"
                Background="{StaticResource SurfaceSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="9">

                <Border.Style>

                    <Style TargetType="Border">

                        <Setter
                            Property="Visibility"
                            Value="Visible" />

                        <Style.Triggers>

                            <DataTrigger
                                Binding="{Binding SelectedDevice}"
                                Value="{x:Null}">

                                <Setter
                                    Property="Visibility"
                                    Value="Visible" />

                            </DataTrigger>

                            <DataTrigger Binding="{Binding SelectedDevice}">

                                <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </Border.Style>

                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Wählen Sie ein Gerät aus, um den gespeicherten Systemcheck anzuzeigen."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />

            </Border>

            <!-- Gerätedetails -->

            <StackPanel
                Grid.Row="4"
                DataContext="{Binding SelectedDevice.CheckupSession}">

                <StackPanel.Style>

                    <Style TargetType="StackPanel">

                        <Setter
                            Property="Visibility"
                            Value="Visible" />

                        <Style.Triggers>

                            <DataTrigger
                                Binding="{Binding DataContext.SelectedDevice, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Value="{x:Null}">

                                <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </StackPanel.Style>

                <Border
                    Padding="18"
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="9">

                    <StackPanel>

                        <TextBlock
                            Text="Gespeicherter Systemcheck"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,4,0,18"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Vollständiger Stand des zuletzt gespeicherten Scans." />

                        <checkup:CheckupDetailsView />

                    </StackPanel>

                </Border>

                <checkup:ProgramUpdatesCard
                    Margin="0,20,0,0"
                    DataContext="{Binding ProgramUpdateInformation}" />

            </StackPanel>

        </Grid>

    </Border>

</UserControl>