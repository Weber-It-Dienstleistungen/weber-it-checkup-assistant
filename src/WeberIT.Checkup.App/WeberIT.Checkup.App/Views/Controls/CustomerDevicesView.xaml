<UserControl x:Class="WeberIT.Checkup.App.Views.Controls.CustomerDevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <Border
        Margin="0,24,0,0"
        Padding="16"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="8">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        Text="Geräte"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{Binding DeviceCountText}" />

                </StackPanel>

                <Button
                    Grid.Column="3"
                    Width="120"
                    Content="Neu scannen"
                    Command="{Binding RescanDeviceCommand}" />

                <Button
                    Grid.Column="5"
                    Width="110"
                    Content="Löschen"
                    Command="{Binding DeleteDeviceCommand}" />

                <Button
                    Grid.Column="7"
                    Width="140"
                    Content="Gerät hinzufügen"
                    Command="{Binding AddDeviceCommand}" />

            </Grid>

            <ListBox
                Margin="0,16,0,0"
                ItemsSource="{Binding Devices}"
                SelectedItem="{Binding SelectedDevice}"
                BorderThickness="0"
                Background="Transparent">

                <ListBox.ItemContainerStyle>

                    <Style TargetType="ListBoxItem">

                        <Setter
                            Property="HorizontalContentAlignment"
                            Value="Stretch" />

                        <Setter
                            Property="Padding"
                            Value="0" />

                        <Setter
                            Property="Margin"
                            Value="0" />

                    </Style>

                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Padding="12"
                            Margin="0,0,0,8"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <StackPanel>

                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{Binding DisplayName}" />

                                <StackPanel
                                    Margin="0,4,0,0"
                                    Orientation="Horizontal">

                                    <StackPanel.Style>

                                        <Style TargetType="StackPanel">

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />

                                            <Style.Triggers>

                                                <MultiDataTrigger>

                                                    <MultiDataTrigger.Conditions>

                                                        <Condition
                                                            Binding="{Binding CheckupSession.DeviceInformation.Manufacturer}"
                                                            Value="{x:Static sys:String.Empty}" />

                                                        <Condition
                                                            Binding="{Binding CheckupSession.DeviceInformation.Model}"
                                                            Value="{x:Static sys:String.Empty}" />

                                                    </MultiDataTrigger.Conditions>

                                                    <Setter
                                                        Property="Visibility"
                                                        Value="Collapsed" />

                                                </MultiDataTrigger>

                                            </Style.Triggers>

                                        </Style>

                                    </StackPanel.Style>

                                    <TextBlock
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding CheckupSession.DeviceInformation.Manufacturer}" />

                                    <TextBlock
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text=" · ">

                                        <TextBlock.Style>

                                            <Style TargetType="TextBlock">

                                                <Setter
                                                    Property="Visibility"
                                                    Value="Visible" />

                                                <Style.Triggers>

                                                    <DataTrigger
                                                        Binding="{Binding CheckupSession.DeviceInformation.Manufacturer}"
                                                        Value="{x:Static sys:String.Empty}">

                                                        <Setter
                                                            Property="Visibility"
                                                            Value="Collapsed" />

                                                    </DataTrigger>

                                                    <DataTrigger
                                                        Binding="{Binding CheckupSession.DeviceInformation.Model}"
                                                        Value="{x:Static sys:String.Empty}">

                                                        <Setter
                                                            Property="Visibility"
                                                            Value="Collapsed" />

                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>

                                        </TextBlock.Style>

                                    </TextBlock>

                                    <TextBlock
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="{Binding CheckupSession.DeviceInformation.Model}" />

                                </StackPanel>

                                <TextBlock
                                    Margin="0,4,0,0"
                                    Foreground="{StaticResource TextSecondaryBrush}">

                                    <TextBlock.Text>

                                        <MultiBinding StringFormat="{}Letzter Scan: {0:dd.MM.yyyy HH:mm}">
                                            <Binding Path="CheckupSession.ScanDate" />
                                        </MultiBinding>

                                    </TextBlock.Text>

                                </TextBlock>

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ListBox.ItemTemplate>

            </ListBox>

        </StackPanel>

    </Border>

</UserControl>