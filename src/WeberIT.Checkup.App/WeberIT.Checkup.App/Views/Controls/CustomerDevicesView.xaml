<UserControl x:Class="WeberIT.Checkup.App.Views.Controls.CustomerDevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Margin="0,24,0,0"
        Padding="16"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="8">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock
                        Text="Geräte"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{Binding DeviceCountText}" />

                </StackPanel>

                <Button
                    Grid.Column="3"
                    Width="140"
                    Content="Gerät hinzufügen"
                    Command="{Binding AddDeviceCommand}" />

            </Grid>

            <ItemsControl
                Margin="0,16,0,0"
                ItemsSource="{Binding Devices}">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Padding="12"
                            Margin="0,0,0,8"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <StackPanel>

                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{Binding DisplayName}" />

                                <TextBlock
                                    Margin="0,4,0,0"
                                    Foreground="{StaticResource TextSecondaryBrush}">

                                    <TextBlock.Text>

                                        <MultiBinding StringFormat="{}Letzter Scan: {0:dd.MM.yyyy HH:mm}">
                                            <Binding Path="CheckupSession.ScanDate" />
                                        </MultiBinding>

                                    </TextBlock.Text>

                                </TextBlock>

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </StackPanel>

    </Border>

</UserControl>