<UserControl x:Class="WeberIT.Checkup.App.Views.Controls.Shared.InfoRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Grid Margin="{Binding RowMargin, ElementName=Root}">

        <Grid.ColumnDefinitions>

            <ColumnDefinition
                Width="{Binding LabelWidth, ElementName=Root}" />

            <ColumnDefinition Width="*" />

        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Column="0"
            Margin="0,0,16,0"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="{Binding Label, ElementName=Root}"
            TextWrapping="Wrap"
            VerticalAlignment="Top" />

        <TextBlock
            Grid.Column="1"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="{Binding Value, ElementName=Root}"
            TextWrapping="Wrap"
            VerticalAlignment="Top" />

    </Grid>

</UserControl>