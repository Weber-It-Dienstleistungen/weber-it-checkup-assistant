<UserControl x:Class="WeberIT.Checkup.App.Views.Pages.MaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:WeberIT.Checkup.App.Models">

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled"
        Background="{StaticResource BackgroundBrush}">

        <Grid Margin="40,32,40,40">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Seitenüberschrift -->

            <StackPanel Grid.Row="0">

                <TextBlock
                    Text="{Binding Title}"
                    Style="{StaticResource PageTitleTextStyle}" />

                <TextBlock
                    Margin="0,6,0,0"
                    Text="{Binding Subtitle}"
                    Style="{StaticResource PageSubtitleTextStyle}" />

            </StackPanel>

            <!-- SFC-Werkzeugkarte -->

            <Border
                Grid.Row="2"
                Padding="24"
                Style="{StaticResource PanelCardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Werkzeugkopf -->

                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Width="46"
                            Height="46"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="10">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="21"
                                Foreground="{StaticResource AccentBrush}"
                                Text="&#xE9D9;" />

                        </Border>

                        <StackPanel Grid.Column="1">

                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Windows-Systemdateiprüfung (SFC)" />

                            <TextBlock
                                Margin="0,5,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Überprüft die geschützten Windows-Systemdateien und repariert erkannte Beschädigungen, soweit dies möglich ist."
                                TextWrapping="Wrap" />

                        </StackPanel>

                        <!-- Statusanzeige -->

                        <Border
                            Grid.Column="3"
                            Padding="12,7"
                            VerticalAlignment="Top"
                            BorderThickness="1"
                            CornerRadius="7">

                            <Border.Style>

                                <Style TargetType="Border">

                                    <Setter
                                        Property="Background"
                                        Value="{StaticResource SurfaceSecondaryBrush}" />

                                    <Setter
                                        Property="BorderBrush"
                                        Value="{StaticResource BorderBrush}" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding SfcResult.Status}"
                                            Value="{x:Static models:MaintenanceToolStatus.Running}">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource InformationBrush}" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding SfcResult.Status}"
                                            Value="{x:Static models:MaintenanceToolStatus.Successful}">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource SuccessBrush}" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding SfcResult.Status}"
                                            Value="{x:Static models:MaintenanceToolStatus.SuccessfulWithRepairs}">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource SuccessBrush}" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding SfcResult.Status}"
                                            Value="{x:Static models:MaintenanceToolStatus.ActionRequired}">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource WarningBrush}" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding SfcResult.Status}"
                                            Value="{x:Static models:MaintenanceToolStatus.RestartRequired}">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource WarningBrush}" />

                                        </DataTrigger>

                                        <DataTrigger
                                            Binding="{Binding SfcResult.Status}"
                                            Value="{x:Static models:MaintenanceToolStatus.Failed}">

                                            <Setter
                                                Property="BorderBrush"
                                                Value="{StaticResource DangerBrush}" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </Border.Style>

                            <StackPanel Orientation="Horizontal">

                                <Ellipse
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">

                                    <Ellipse.Style>

                                        <Style TargetType="Ellipse">

                                            <Setter
                                                Property="Fill"
                                                Value="{StaticResource TextMutedBrush}" />

                                            <Style.Triggers>

                                                <DataTrigger
                                                    Binding="{Binding SfcResult.Status}"
                                                    Value="{x:Static models:MaintenanceToolStatus.Running}">

                                                    <Setter
                                                        Property="Fill"
                                                        Value="{StaticResource InformationBrush}" />

                                                </DataTrigger>

                                                <DataTrigger
                                                    Binding="{Binding SfcResult.Status}"
                                                    Value="{x:Static models:MaintenanceToolStatus.Successful}">

                                                    <Setter
                                                        Property="Fill"
                                                        Value="{StaticResource SuccessBrush}" />

                                                </DataTrigger>

                                                <DataTrigger
                                                    Binding="{Binding SfcResult.Status}"
                                                    Value="{x:Static models:MaintenanceToolStatus.SuccessfulWithRepairs}">

                                                    <Setter
                                                        Property="Fill"
                                                        Value="{StaticResource SuccessBrush}" />

                                                </DataTrigger>

                                                <DataTrigger
                                                    Binding="{Binding SfcResult.Status}"
                                                    Value="{x:Static models:MaintenanceToolStatus.ActionRequired}">

                                                    <Setter
                                                        Property="Fill"
                                                        Value="{StaticResource WarningBrush}" />

                                                </DataTrigger>

                                                <DataTrigger
                                                    Binding="{Binding SfcResult.Status}"
                                                    Value="{x:Static models:MaintenanceToolStatus.RestartRequired}">

                                                    <Setter
                                                        Property="Fill"
                                                        Value="{StaticResource WarningBrush}" />

                                                </DataTrigger>

                                                <DataTrigger
                                                    Binding="{Binding SfcResult.Status}"
                                                    Value="{x:Static models:MaintenanceToolStatus.Failed}">

                                                    <Setter
                                                        Property="Fill"
                                                        Value="{StaticResource DangerBrush}" />

                                                </DataTrigger>

                                            </Style.Triggers>

                                        </Style>

                                    </Ellipse.Style>

                                </Ellipse>

                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding SfcStatusText}" />

                            </StackPanel>

                        </Border>

                    </Grid>

                    <!-- Administratorhinweis -->

                    <Border
                        Grid.Row="2"
                        Padding="14,11"
                        Background="{StaticResource SurfaceSecondaryBrush}"
                        BorderBrush="{StaticResource InformationBrush}"
                        BorderThickness="1"
                        CornerRadius="7">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Top"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="15"
                                Foreground="{StaticResource InformationBrush}"
                                Text="&#xE72E;" />

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding AdministratorNotice}"
                                TextWrapping="Wrap" />

                        </Grid>

                    </Border>

                    <!-- Ergebnis und Startschaltfläche -->

                    <Grid
                        Grid.Row="3"
                        Margin="0,20,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="230" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center">

                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{Binding SfcSummary}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,6,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding SfcDetails}"
                                TextWrapping="Wrap" />

                            <ProgressBar
                                Height="5"
                                Margin="0,14,0,0"
                                IsIndeterminate="True"
                                Foreground="{StaticResource InformationBrush}">

                                <ProgressBar.Style>

                                    <Style TargetType="ProgressBar">

                                        <Setter
                                            Property="Visibility"
                                            Value="Collapsed" />

                                        <Style.Triggers>

                                            <DataTrigger
                                                Binding="{Binding IsSfcRunning}"
                                                Value="True">

                                                <Setter
                                                    Property="Visibility"
                                                    Value="Visible" />

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>

                                </ProgressBar.Style>

                            </ProgressBar>

                        </StackPanel>

                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center">

                            <Button
                                Width="230"
                                Height="42"
                                Command="{Binding RunSfcCommand}"
                                Content="{Binding SfcButtonText}"
                                Style="{StaticResource AccentButtonStyle}" />

                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="Ausführung: sfc.exe /scannow" />

                        </StackPanel>

                    </Grid>

                    <!-- Technische Details -->

                    <Expander
                        Grid.Row="4"
                        Margin="0,20,0,0"
                        Header="Technische Details">

                        <Expander.Style>

                            <Style TargetType="Expander">

                                <Setter
                                    Property="Visibility"
                                    Value="Collapsed" />

                                <Style.Triggers>

                                    <DataTrigger
                                        Binding="{Binding HasSfcTechnicalDetails}"
                                        Value="True">

                                        <Setter
                                            Property="Visibility"
                                            Value="Visible" />

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </Expander.Style>

                        <Border
                            Margin="0,10,0,0"
                            Padding="14"
                            Background="{StaticResource PrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="7">

                            <ScrollViewer
                                MaxHeight="320"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto">

                                <TextBlock
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding SfcTechnicalDetails}"
                                    TextWrapping="NoWrap" />

                            </ScrollViewer>

                        </Border>

                    </Expander>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</UserControl>