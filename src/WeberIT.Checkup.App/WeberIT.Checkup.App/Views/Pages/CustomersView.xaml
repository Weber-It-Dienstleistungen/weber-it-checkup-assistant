<UserControl x:Class="WeberIT.Checkup.App.Views.Pages.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24">

        <Border Style="{StaticResource PanelCardStyle}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Grid
                    Grid.Row="0"
                    Grid.Column="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Text="Kunden"
                        Style="{StaticResource SectionTitleTextStyle}" />

                    <Button
                        Grid.Column="1"
                        Width="130"
                        Content="Neu"
                        Command="{Binding AddCustomerCommand}" />

                </Grid>

                <StackPanel
                    Grid.Row="2"
                    Grid.Column="0">

                    <TextBox
                        Height="36"
                        Margin="0,0,0,12"
                        Padding="10,0"
                        VerticalContentAlignment="Center"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <ListBox
                        ItemsSource="{Binding CustomersView}"
                        SelectedItem="{Binding SelectedCustomer}"
                        BorderThickness="0">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border
                                    Padding="12"
                                    Margin="0,0,0,8"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">

                                    <StackPanel>

                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Text="{Binding DisplayName}" />

                                        <TextBlock
                                            Margin="0,4,0,0"
                                            Foreground="{StaticResource TextSecondaryBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} · {1}">
                                                    <Binding Path="CustomerNumber" />
                                                    <Binding Path="City" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </StackPanel>

                <Border
                    Grid.Row="2"
                    Grid.Column="2"
                    Padding="16"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            Text="Kundendetails"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,16,0,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.DisplayName}" />

                        <TextBlock
                            Margin="0,16,0,0"
                            Text="Kundennummer" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.CustomerNumber}" />

                        <TextBlock
                            Margin="0,12,0,0"
                            Text="E-Mail" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.Email}" />

                        <TextBlock
                            Margin="0,12,0,0"
                            Text="Telefon" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.Phone}" />

                        <TextBlock
                            Margin="0,12,0,0"
                            Text="Adresse" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.Street}" />

                        <TextBlock
                            FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="SelectedCustomer.PostalCode" />
                                    <Binding Path="SelectedCustomer.City" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

    </Grid>

</UserControl>