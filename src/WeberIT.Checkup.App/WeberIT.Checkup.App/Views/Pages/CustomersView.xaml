<UserControl x:Class="WeberIT.Checkup.App.Views.Pages.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24">

        <Border Style="{StaticResource PanelCardStyle}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Text="Kunden"
                    Style="{StaticResource SectionTitleTextStyle}" />

                <ListView
                    Grid.Row="2"
                    ItemsSource="{Binding Customers}">

                    <ListView.View>

                        <GridView>

                            <GridViewColumn
                                Header="Kundennummer"
                                Width="120"
                                DisplayMemberBinding="{Binding CustomerNumber}" />

                            <GridViewColumn
                                Header="Name"
                                Width="220"
                                DisplayMemberBinding="{Binding DisplayName}" />

                            <GridViewColumn
                                Header="Ort"
                                Width="180"
                                DisplayMemberBinding="{Binding City}" />

                        </GridView>

                    </ListView.View>

                </ListView>

            </Grid>

        </Border>

    </Grid>

</UserControl>