<UserControl x:Class="WeberIT.Checkup.App.Views.Pages.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24">

        <Border Style="{StaticResource PanelCardStyle}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="Kunden"
                    Style="{StaticResource SectionTitleTextStyle}" />

                <ListView
                    Grid.Row="2"
                    Grid.Column="0"
                    ItemsSource="{Binding Customers}"
                    SelectedItem="{Binding SelectedCustomer}">

                    <ListView.View>
                        <GridView>
                            <GridViewColumn
                                Header="Kundennummer"
                                Width="120"
                                DisplayMemberBinding="{Binding CustomerNumber}" />

                            <GridViewColumn
                                Header="Name"
                                Width="220"
                                DisplayMemberBinding="{Binding DisplayName}" />

                            <GridViewColumn
                                Header="Ort"
                                Width="180"
                                DisplayMemberBinding="{Binding City}" />
                        </GridView>
                    </ListView.View>

                </ListView>

                <Border
                    Grid.Row="2"
                    Grid.Column="2"
                    Padding="16"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <StackPanel>

                        <TextBlock
                            Text="Kundendetails"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,16,0,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.DisplayName}" />

                        <TextBlock
                            Margin="0,16,0,0"
                            Text="Kundennummer" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.CustomerNumber}" />

                        <TextBlock
                            Margin="0,12,0,0"
                            Text="E-Mail" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.Email}" />

                        <TextBlock
                            Margin="0,12,0,0"
                            Text="Telefon" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.Phone}" />

                        <TextBlock
                            Margin="0,12,0,0"
                            Text="Adresse" />

                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding SelectedCustomer.Street}" />

                        <TextBlock
                            FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="SelectedCustomer.PostalCode" />
                                    <Binding Path="SelectedCustomer.City" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

    </Grid>

</UserControl>