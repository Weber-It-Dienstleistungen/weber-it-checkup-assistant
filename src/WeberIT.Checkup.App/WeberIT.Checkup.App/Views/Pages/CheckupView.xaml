<UserControl x:Class="WeberIT.Checkup.App.Views.Pages.CheckupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WeberIT.Checkup.App.Infrastructure.Converters">

    <UserControl.Resources>
        <converters:FindingSeverityToSymbolConverter x:Key="FindingSeverityToSymbolConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40">

                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource PageTitleTextStyle}" />

                        <TextBlock Text="{Binding Subtitle}"
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,6,0,0" />

                        <TextBlock Text="{Binding ScanStatusText}"
                                   Margin="0,10,0,0"
                                   Foreground="#666666" />
                    </StackPanel>

                    <Button Content="System auslesen"
                            Command="{Binding ReadSystemCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="160"
                            Height="38"
                            DockPanel.Dock="Right" />
                </DockPanel>

                <Grid Margin="0,32,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Allgemeine Informationen -->

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Allgemeine Informationen"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Computername:"
                                           FontWeight="SemiBold" />

                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding DeviceInformation.Name}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Gerätetyp:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding DeviceInformation.DeviceType}"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Hersteller:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding DeviceInformation.Manufacturer}"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="Modell:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           Text="{Binding DeviceInformation.Model}"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Text="Seriennummer:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Text="{Binding DeviceInformation.SerialNumber}"
                                           Margin="0,8,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Hardware -->

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Hardware"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Prozessor:"
                                           FontWeight="SemiBold" />

                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.ProcessorName}"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Arbeitsspeicher:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.InstalledMemory}"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Mainboard-Hersteller:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.MainboardManufacturer}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="Mainboard-Modell:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.MainboardProduct}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Text="BIOS-Hersteller:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.BiosManufacturer}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Text="BIOS-Version:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="5"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.BiosVersion}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Text="TPM-Status:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.TpmStatus}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Text="TPM-Version:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="7"
                                           Grid.Column="1"
                                           Text="{Binding HardwareInformation.TpmVersion}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                            </Grid>

                            <TextBlock Text="Grafikkarten"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#222222"
                                       Margin="0,24,0,0" />

                            <ItemsControl ItemsSource="{Binding HardwareInformation.GraphicsCards}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Laufwerke"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#222222"
                                       Margin="0,24,0,0" />

                            <ItemsControl ItemsSource="{Binding HardwareInformation.Drives}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,6,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Model}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />

                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Capacity}" />
                                                    <TextBlock Text=" | " />
                                                    <TextBlock Text="{Binding DriveType}" />
                                                    <TextBlock Text=" | " />
                                                    <TextBlock Text="{Binding Manufacturer}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Betriebssystem -->

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Software / System"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Windows:"
                                           FontWeight="SemiBold" />

                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding OperatingSystemInformation.Name}"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Version:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding OperatingSystemInformation.Version}"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Build:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding OperatingSystemInformation.BuildNumber}"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="Architektur:"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           Text="{Binding OperatingSystemInformation.Architecture}"
                                           Margin="0,8,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Bewertung -->

                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Bewertung"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <ItemsControl ItemsSource="{Binding Assessment.Findings}"
                                          Margin="0,16,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12"
                                                Margin="0,0,0,10"
                                                Background="#F7F7F7"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="8">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="32" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Severity, Converter={StaticResource FindingSeverityToSymbolConverter}}"
                                                           FontSize="18"
                                                           VerticalAlignment="Top" />

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#222222"
                                                               TextWrapping="Wrap" />

                                                    <TextBlock Text="{Binding Description}"
                                                               Margin="0,4,0,0"
                                                               Foreground="#666666"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Storage / Datenträger -->

                    <Border Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Storage / Datenträger"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <TextBlock Text="Physische Laufwerke"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#222222"
                                       Margin="0,20,0,0" />

                            <ItemsControl ItemsSource="{Binding StorageInformation.PhysicalDrives}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12"
                                                Margin="0,0,0,10"
                                                Background="#F7F7F7"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="8">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Model}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Capacity}"
                                                           Margin="16,0,0,0" />

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DriveType}"
                                                           Margin="16,0,0,0" />

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Manufacturer}"
                                                           Margin="16,0,0,0"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Volumes / Laufwerksbuchstaben"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#222222"
                                       Margin="0,20,0,0" />

                            <ItemsControl ItemsSource="{Binding StorageInformation.Volumes}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12"
                                                Margin="0,0,0,10"
                                                Background="#F7F7F7"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="8">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="90" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DriveLetter}"
                                                           FontWeight="SemiBold" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DriveType}"
                                                           Margin="16,0,0,0" />

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding FileSystem}"
                                                           Margin="16,0,0,0" />

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TotalSize}"
                                                           Margin="16,0,0,0" />

                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding FreeSpace}"
                                                           Margin="16,0,0,0" />

                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding IsReady}"
                                                           Margin="16,0,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>