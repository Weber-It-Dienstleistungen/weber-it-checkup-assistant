<UserControl x:Class="WeberIT.Checkup.App.Views.Pages.CheckupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:checkup="clr-namespace:WeberIT.Checkup.App.Views.Controls.Checkup">

    <Grid Background="{StaticResource BackgroundBrush}">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="40">

                <DockPanel>

                    <StackPanel>

                        <TextBlock
                            Text="{Binding Title}"
                            Style="{StaticResource PageTitleTextStyle}" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Text="{Binding Subtitle}"
                            Style="{StaticResource PageSubtitleTextStyle}" />

                        <TextBlock
                            Margin="0,10,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{Binding ScanStatusText}" />

                    </StackPanel>

                    <Button
                        Width="160"
                        Height="38"
                        Content="System auslesen"
                        Command="{Binding ReadSystemCommand}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource AccentButtonStyle}" />

                </DockPanel>

                <checkup:CheckupDetailsView
                    Margin="0,32,0,0"
                    DataContext="{Binding CurrentCheckup}" />

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>