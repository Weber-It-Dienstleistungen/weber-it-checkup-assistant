<UserControl x:Class="WeberIT.Checkup.App.Views.Pages.CheckupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40">

                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource PageTitleTextStyle}" />

                        <TextBlock Text="{Binding Subtitle}"
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <Button Content="System auslesen"
                            Command="{Binding ReadSystemCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="160"
                            Height="38"
                            DockPanel.Dock="Right" />
                </DockPanel>

                <Grid Margin="0,32,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Allgemeine Informationen"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <TextBlock Text="Computername, Gerätetyp, Hersteller, Modell, Seriennummer und BIOS-Version."
                                       Margin="0,8,0,0"
                                       Foreground="#666666"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="2"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Hardware"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <TextBlock Text="Prozessor, Arbeitsspeicher, Grafikkarte, Mainboard und Datenträger."
                                       Margin="0,8,0,0"
                                       Foreground="#666666"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Software / System"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <TextBlock Text="Windows-Version, Build, Architektur, Updates und relevante Systemzustände."
                                       Margin="0,8,0,0"
                                       Foreground="#666666"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="2"
                            Padding="24"
                            Background="White"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="10">

                        <StackPanel>
                            <TextBlock Text="Checkup-Status"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#222222" />

                            <TextBlock Text="Hier entstehen später Prüfergebnisse, Warnungen und Empfehlungen."
                                       Margin="0,8,0,0"
                                       Foreground="#666666"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>