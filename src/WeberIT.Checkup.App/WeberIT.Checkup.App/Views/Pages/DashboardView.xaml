<UserControl
    x:Class="WeberIT.Checkup.App.Views.Pages.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer
        Background="{StaticResource BackgroundBrush}"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">

        <Grid Margin="40,32,40,40">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Überschrift -->

            <StackPanel Grid.Row="0">

                <TextBlock
                    Text="Dashboard"
                    Style="{StaticResource PageTitleTextStyle}" />

                <TextBlock
                    Margin="0,6,0,0"
                    Text="{Binding WelcomeText}"
                    Style="{StaticResource PageSubtitleTextStyle}" />

            </StackPanel>

            <!-- Kennzahlen -->

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Kunden -->

                <Border
                    Grid.Column="0"
                    Padding="20"
                    Style="{StaticResource PanelCardStyle}">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Width="38"
                            Height="38"
                            VerticalAlignment="Top"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="8">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="18"
                                Foreground="{StaticResource AccentBrush}"
                                Text="&#xE716;" />

                        </Border>

                        <StackPanel Grid.Column="1">

                            <TextBlock
                                Text="KUNDEN"
                                Style="{StaticResource CardTitleTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                Text="{Binding CustomerCount}"
                                Style="{StaticResource CardNumberTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="gespeicherte Kunden" />

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- Geräte -->

                <Border
                    Grid.Column="2"
                    Padding="20"
                    Style="{StaticResource PanelCardStyle}">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Width="38"
                            Height="38"
                            VerticalAlignment="Top"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="8">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="18"
                                Foreground="{StaticResource InformationBrush}"
                                Text="&#xE7F8;" />

                        </Border>

                        <StackPanel Grid.Column="1">

                            <TextBlock
                                Text="GERÄTE"
                                Style="{StaticResource CardTitleTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                Text="{Binding DeviceCount}"
                                Style="{StaticResource CardNumberTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="inventarisierte Geräte" />

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- Checkups -->

                <Border
                    Grid.Column="4"
                    Padding="20"
                    Style="{StaticResource PanelCardStyle}">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Width="38"
                            Height="38"
                            VerticalAlignment="Top"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="8">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="18"
                                Foreground="{StaticResource SuccessBrush}"
                                Text="&#xE9D9;" />

                        </Border>

                        <StackPanel Grid.Column="1">

                            <TextBlock
                                Text="CHECKUPS"
                                Style="{StaticResource CardTitleTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                Text="{Binding CheckupCount}"
                                Style="{StaticResource CardNumberTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="gespeicherte Scans" />

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- Befunde -->

                <Border
                    Grid.Column="6"
                    Padding="20"
                    Style="{StaticResource PanelCardStyle}">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Width="38"
                            Height="38"
                            VerticalAlignment="Top"
                            Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="8">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="18"
                                Foreground="{StaticResource WarningBrush}"
                                Text="&#xE7BA;" />

                        </Border>

                        <StackPanel Grid.Column="1">

                            <TextBlock
                                Text="BEFUNDE"
                                Style="{StaticResource CardTitleTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                Text="{Binding RecommendationCount}"
                                Style="{StaticResource CardNumberTextStyle}" />

                            <TextBlock
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="prüfungsrelevante Hinweise" />

                        </StackPanel>

                    </Grid>

                </Border>

            </Grid>

            <!-- Aktivitäten und Bestandsübersicht -->

            <Grid Grid.Row="4">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Letzte Aktivitäten -->

                <Border
                    Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Text="Letzte Aktivitäten"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <Grid Grid.Row="2">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text="Noch keine Aktivitäten vorhanden.">

                                <TextBlock.Style>

                                    <Style TargetType="TextBlock">

                                        <Setter
                                            Property="Visibility"
                                            Value="Collapsed" />

                                        <Style.Triggers>

                                            <DataTrigger
                                                Binding="{Binding HasRecentActivities}"
                                                Value="False">

                                                <Setter
                                                    Property="Visibility"
                                                    Value="Visible" />

                                            </DataTrigger>

                                        </Style.Triggers>

                                    </Style>

                                </TextBlock.Style>

                            </TextBlock>

                            <ItemsControl
                                ItemsSource="{Binding RecentActivities}">

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <Grid Margin="0,0,0,14">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border
                                                Grid.Column="0"
                                                Width="30"
                                                Height="30"
                                                VerticalAlignment="Top"
                                                Background="{StaticResource SurfaceSecondaryBrush}"
                                                CornerRadius="15">

                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="13"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    Text="&#xE946;" />

                                            </Border>

                                            <StackPanel Grid.Column="1">

                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    Text="{Binding Title}" />

                                                <TextBlock
                                                    Margin="0,3,0,0"
                                                    FontSize="12"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding Description}"
                                                    TextTrimming="CharacterEllipsis" />

                                            </StackPanel>

                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="16,2,0,0"
                                                VerticalAlignment="Top"
                                                FontSize="11"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                Text="{Binding TimestampText}" />

                                        </Grid>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </Grid>

                    </Grid>

                </Border>

                <!-- Neutrale Bestandsübersicht -->

                <Border
                    Grid.Column="2"
                    Style="{StaticResource PanelCardStyle}">

                    <StackPanel>

                        <TextBlock
                            Text="Bestandsübersicht"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <TextBlock
                            Margin="0,6,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Geräteübergreifende Verwaltungsinformationen ohne vermeintlichen Geräte- oder Kundenscore."
                            TextWrapping="Wrap" />

                        <Border
                            Margin="0,20,0,0"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Top"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource SuccessBrush}"
                                    Text="&#xE73E;" />

                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding ScannedDevicesText}"
                                    TextWrapping="Wrap" />

                            </Grid>

                        </Border>

                        <Border
                            Margin="0,10,0,0"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Top"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource InformationBrush}"
                                    Text="&#xE9D9;" />

                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding UnscannedDevicesText}"
                                    TextWrapping="Wrap" />

                            </Grid>

                        </Border>

                        <Border
                            Margin="0,10,0,0"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Top"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource WarningBrush}"
                                    Text="&#xE7BA;" />

                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding DevicesWithOpenFindingsText}"
                                    TextWrapping="Wrap" />

                            </Grid>

                        </Border>

                        <Border
                            Margin="0,10,0,0"
                            Padding="14"
                            Background="{StaticResource BackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Top"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="16"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Text="&#xE823;" />

                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{Binding LegacyCheckupsText}"
                                    TextWrapping="Wrap" />

                            </Grid>

                        </Border>

                        <TextBlock
                            Margin="0,14,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="System- und Hardwarezustände werden ausschließlich beim jeweiligen Gerät angezeigt. Ein Checkup-Abschlussgrad wird erst mit dem späteren Vorgangsmodell eingeführt."
                            TextWrapping="Wrap" />

                    </StackPanel>

                </Border>

            </Grid>

            <!-- Priorisierte Befunde -->

            <Border
                Grid.Row="6"
                Padding="20"
                Style="{StaticResource PanelCardStyle}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock
                                Text="Befunde mit hoher Priorität"
                                Style="{StaticResource SectionTitleTextStyle}" />

                            <TextBlock
                                Margin="0,4,0,0"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Geräteübergreifende Übersicht der wichtigsten offenen Befunde. Die jeweilige Gerätebewertung befindet sich in den Gerätedetails."
                                TextWrapping="Wrap" />

                        </StackPanel>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="Maximal 5 Einträge" />

                    </Grid>

                    <Grid Grid.Row="2">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextMutedBrush}"
                            Text="Aktuell liegen keine priorisierten Befunde vor.">

                            <TextBlock.Style>

                                <Style TargetType="TextBlock">

                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />

                                    <Style.Triggers>

                                        <DataTrigger
                                            Binding="{Binding HasPriorityRecommendations}"
                                            Value="False">

                                            <Setter
                                                Property="Visibility"
                                                Value="Visible" />

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </TextBlock.Style>

                        </TextBlock>

                        <ItemsControl
                            ItemsSource="{Binding PriorityRecommendations}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        Background="{StaticResource SurfaceSecondaryBrush}"
                                        CornerRadius="8">

                                        <Grid>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Top"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="17"
                                                Foreground="{StaticResource WarningBrush}"
                                                Text="&#xE7BA;" />

                                            <StackPanel Grid.Column="1">

                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    Text="{Binding Title}"
                                                    TextWrapping="Wrap" />

                                                <TextBlock
                                                    Margin="0,3,0,0"
                                                    FontSize="12"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding Description}"
                                                    TextWrapping="Wrap" />

                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontSize="11"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    Text="{Binding ContextText}" />

                                            </StackPanel>

                                            <Border
                                                Grid.Column="2"
                                                Margin="16,0,0,0"
                                                Padding="10,4"
                                                VerticalAlignment="Top"
                                                Background="{StaticResource BackgroundBrush}"
                                                BorderBrush="{StaticResource WarningBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">

                                                <TextBlock
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource WarningBrush}"
                                                    Text="{Binding SeverityText}" />

                                            </Border>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </Grid>

                    <Grid Grid.Row="4">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Width="160"
                            Height="40"
                            Content="Neuer Checkup"
                            Command="{Binding StartCheckupCommand}"
                            Style="{StaticResource AccentButtonStyle}" />

                        <Button
                            Grid.Column="2"
                            Width="160"
                            Height="40"
                            Content="Kunden verwalten"
                            Command="{Binding ShowCustomersCommand}" />

                    </Grid>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</UserControl>