<Application x:Class="WeberIT.Checkup.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:WeberIT.Checkup.App.ViewModels"
             xmlns:views="clr-namespace:WeberIT.Checkup.App.Views.Pages">

    <Application.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Typography.xaml" />
                <ResourceDictionary Source="Resources/Styles/Theme.xaml" />
                <ResourceDictionary Source="Resources/Styles/Buttons.xaml" />
                <ResourceDictionary Source="Resources/Styles/Cards.xaml" />
                <ResourceDictionary Source="Resources/Styles/Forms.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:CustomersViewModel}">
                <views:CustomersView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:CheckupViewModel}">
                <views:CheckupView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:MaintenanceViewModel}">
                <views:MaintenanceView />
            </DataTemplate>

        </ResourceDictionary>

    </Application.Resources>

</Application>