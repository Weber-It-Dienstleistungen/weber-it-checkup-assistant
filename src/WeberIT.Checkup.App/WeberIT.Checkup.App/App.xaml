<Application x:Class="WeberIT.Checkup.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:WeberIT.Checkup.App.ViewModels"
             xmlns:views="clr-namespace:WeberIT.Checkup.App.Views.Pages">

    <Application.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Typography.xaml" />
                <ResourceDictionary Source="Resources/Styles/Buttons.xaml" />
                <ResourceDictionary Source="Resources/Styles/Cards.xaml" />
                <ResourceDictionary Source="Resources/Styles/Forms.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:CustomersViewModel}">
                <views:CustomersView />
            </DataTemplate>

            <Style x:Key="NavButtonStyle"
                   TargetType="Button">

                <Setter Property="Height"
                        Value="44"/>

                <Setter Property="Margin"
                        Value="12,2"/>

                <Setter Property="Padding"
                        Value="18,0"/>

                <Setter Property="HorizontalContentAlignment"
                        Value="Left"/>

                <Setter Property="Background"
                        Value="Transparent"/>

                <Setter Property="Foreground"
                        Value="{StaticResource SurfaceBrush}"/>

                <Setter Property="BorderThickness"
                        Value="0"/>

                <Setter Property="FontSize"
                        Value="14"/>

            </Style>

        </ResourceDictionary>

    </Application.Resources>

</Application>